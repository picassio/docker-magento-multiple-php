# =============================================================================
# Docker Magento - Environment Configuration
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
MYSQL_VERSION=8.4
MYSQL_DATABASE=magento
MYSQL_USER=magento
MYSQL_PASSWORD=magento
MYSQL_ROOT_PASSWORD=root
# Uncomment for MariaDB (start with: docker compose --profile mariadb up -d)
# MARIADB_VERSION=11.4

# ── Search Engine ─────────────────────────────────────────────────────────────
OPENSEARCH_VERSION=2.19.1
# Uncomment for Elasticsearch (start with: docker compose --profile elasticsearch up -d)
# ELASTICSEARCH_VERSION=8.17.0

# ── Services ──────────────────────────────────────────────────────────────────
REDIS_VERSION=7.4
RABBITMQ_VERSION=4.1
RABBITMQ_ERLANG_COOKIE=RABBITMQ_ERLANG_COOKIE
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin
VARNISH_VERSION=7.6

# ── Ports (change if conflicts on your host) ──────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
MYSQL_PORT=3306
PHPMYADMIN_PORT=8080
MAILPIT_PORT=8025
RABBITMQ_MGMT_PORT=15672
OPENSEARCH_PORT=9200
REDIS_PORT=6379
REDISCMD_PORT=8081
