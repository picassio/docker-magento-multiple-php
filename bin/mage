#!/usr/bin/env bash
# =============================================================================
# mage — Single CLI entrypoint for Docker Magento Multi-PHP stack
# =============================================================================
MAGE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$MAGE_ROOT" || exit 1
source "${MAGE_ROOT}/scripts/lib/projects.sh"

MAGE_VERSION="2.0.0"
SCRIPTS_DIR="${MAGE_ROOT}/scripts"

# ── Helper: resolve domain → PHP version ──────────────────────────────────────
resolve_php() {
    local arg="$1"
    if [[ "$arg" == *"."* ]] && project_exists "$arg"; then
        project_get "$arg" "php"
    else
        echo "$arg"
    fi
}

# ── Help ──────────────────────────────────────────────────────────────────────
show_help() {
    cat <<EOF
${_green}${_bold}mage${_reset} — Docker Magento CLI ${_blue}v${MAGE_VERSION}${_reset}

${_bold}USAGE${_reset}
    bin/mage <command> [options]

${_bold}LIFECYCLE${_reset}
    ${_green}setup${_reset}                              Interactive first-time setup
    ${_green}up${_reset} [services...]                    Smart start (auto from projects.json)
    ${_green}down${_reset}                                Stop & remove containers
    ${_green}stop${_reset}                                Stop all services
    ${_green}restart${_reset} [service]                   Restart all or a specific service
    ${_green}status${_reset}                              Show projects, services & domains
    ${_green}logs${_reset} [service]                      Tail container logs

${_bold}PROJECT MANAGEMENT${_reset}
    ${_green}project list${_reset}                        List all projects with status
    ${_green}project add${_reset} <domain>                Add a project (interactive wizard)
    ${_green}project remove${_reset} <domain>             Remove project from registry
    ${_green}project enable${_reset} <domain>             Enable project & create vhost
    ${_green}project disable${_reset} <domain>            Disable project & remove vhost
    ${_green}project info${_reset} <domain>               Show project configuration
    ${_green}project switch-php${_reset} <domain> <php>   Change PHP version
    ${_green}project switch-db${_reset} <domain> <db>     Change DB service (mysql/mysql80/mariadb)
    ${_green}project switch-search${_reset} <domain> <s>  Change search (opensearch/elasticsearch/none)
    ${_green}project set${_reset} <domain> <field> <val>  Set any project field

${_bold}DEVELOPMENT (accepts domain name — auto-resolves PHP/DB)${_reset}
    ${_green}shell${_reset} <domain|php>                  Open bash in PHP container
    ${_green}composer${_reset} <domain|php> [args...]     Run composer
    ${_green}magento${_reset} <domain> [args...]           Run bin/magento

${_bold}DATABASE (project-aware — auto-routes to correct DB service)${_reset}
    ${_green}db list${_reset} [--db-service=...]           List databases
    ${_green}db create${_reset} <domain|name>              Create database
    ${_green}db drop${_reset} <domain|name>                Drop database
    ${_green}db export${_reset} <domain|name>              Export database
    ${_green}db import${_reset} <domain> <file.sql>        Import SQL file

${_bold}HOSTING${_reset}
    ${_green}vhost${_reset} <domain> <app> <php>           Create nginx virtual host
    ${_green}ssl${_reset} <domain>                         Enable SSL for domain
    ${_green}xdebug${_reset} <on|off|status> <php>         Toggle Xdebug
    ${_green}varnish${_reset} <on|off|status> <domain>     Toggle Varnish

${_bold}INSTALL${_reset}
    ${_green}install${_reset} <ver> <edition> <domain> <php>  Install fresh Magento

${_bold}EXAMPLES${_reset}
    bin/mage project add mysite.com                # Add project (interactive)
    bin/mage up                                    # Smart start all enabled projects
    bin/mage shell mysite.com                      # Shell into project's PHP
    bin/mage composer mysite.com install            # Composer in right container
    bin/mage magento mysite.com cache:flush         # bin/magento for project
    bin/mage db create mysite.com                   # Create DB on project's DB service
    bin/mage db import mysite.com backup.sql        # Import into right DB
    bin/mage project disable oldsite.com            # Disable without data loss
    bin/mage project switch-php mysite.com php84    # Upgrade PHP
    bin/mage project switch-db mysite.com mariadb    # Switch to MariaDB
    bin/mage project switch-search mysite.com elasticsearch

EOF
}

# ── Command: project ──────────────────────────────────────────────────────────
cmd_project() {
    local action="${1:-}"
    [[ -z "$action" ]] && { _error "Usage: bin/mage project <list|add|remove|enable|disable|info|set|switch-php|switch-db|switch-search> [args]"; exit 1; }
    shift

    case "$action" in
        list)          cmd_project_list ;;
        add)           cmd_project_add "$@" ;;
        remove)        cmd_project_remove "$@" ;;
        enable)        cmd_project_enable "$@" ;;
        disable)       cmd_project_disable "$@" ;;
        info)          cmd_project_info "$@" ;;
        set)           cmd_project_set_field "$@" ;;
        switch-php)    cmd_project_switch_php "$@" ;;
        switch-db)     cmd_project_switch_db "$@" ;;
        switch-search) cmd_project_switch_search "$@" ;;
        *)             _die "Unknown project action: $action" ;;
    esac
}

cmd_project_list() {
    _header "Registered Projects"
    echo ""
    printf "  ${_bold}%-25s %-8s %-10s %-10s %-20s %-8s${_reset}\n" "DOMAIN" "PHP" "APP" "DB" "DATABASE" "STATUS"
    printf "  %-25s %-8s %-10s %-10s %-20s %-8s\n" "─────────────────────────" "────────" "──────────" "──────────" "────────────────────" "────────"

    local count=0
    while IFS='|' read -r domain php app db_svc db_name search enabled; do
        [[ -z "$domain" ]] && continue
        count=$((count + 1))
        local status_icon
        if [[ "$enabled" == "true" ]]; then
            status_icon="${_green}●${_reset} on"
        else
            status_icon="${_red}○${_reset} off"
        fi
        printf "  %-25s %-8s %-10s %-10s %-20s %b\n" "$domain" "$php" "$app" "$db_svc" "$db_name" "$status_icon"
    done < <(project_list_raw)

    if [[ $count -eq 0 ]]; then
        echo "  ${_tan}(no projects registered)${_reset}"
        echo ""
        _arrow "Add one with: bin/mage project add <domain>"
    fi
    echo ""
}

cmd_project_add() {
    local domain="${1:-}"
    [[ -z "$domain" ]] && _die "Usage: bin/mage project add <domain>"

    if project_exists "$domain"; then
        _die "Project '$domain' already exists. Use 'project info $domain' to view it."
    fi

    echo ""
    _header "Add Project: $domain"
    echo ""

    # PHP version
    _arrow "Available PHP versions:"
    get_available_php_versions | while read -r v; do echo "    $v"; done
    echo ""
    read -rp "  PHP version [php83]: " php
    php="${php:-php83}"

    # App type
    read -rp "  App type (magento1/magento2/wordpress/laravel/default) [magento2]: " app
    app="${app:-magento2}"

    # DB service
    read -rp "  Database service (mysql/mysql80/mariadb) [mysql]: " db_svc
    db_svc="${db_svc:-mysql}"

    # DB name
    local default_db
    default_db=$(echo "$domain" | tr '.' '_' | tr '-' '_')
    read -rp "  Database name [${default_db}]: " db_name
    db_name="${db_name:-$default_db}"

    # Search engine
    read -rp "  Search engine (opensearch/elasticsearch/none) [opensearch]: " search
    search="${search:-opensearch}"

    # Save
    project_set "$domain" "$php" "$app" "$db_svc" "$db_name" "$search" "true"
    _success "Project '$domain' registered"

    # Create source dir
    if [[ ! -d "${SOURCE_DIR}/${domain}" ]]; then
        mkdir -p "${SOURCE_DIR}/${domain}"
        _success "Created sources/${domain}/"
    fi

    # Offer to create vhost and DB now
    echo ""
    if ask_yes_no "Create nginx vhost now?"; then
        "${SCRIPTS_DIR}/create-vhost" --domain="$domain" --app="$app" --root-dir="$domain" --php-version="$php" 2>&1 || true
    fi

    if ask_yes_no "Create database '${db_name}' on ${db_svc} now?"; then
        if is_service_running "$db_svc" 2>/dev/null; then
            "${SCRIPTS_DIR}/database" create --database-name="$db_name" --db-service="$db_svc" 2>&1 || true
        else
            _warning "Service $db_svc is not running. Start it first, then run: bin/mage db create $domain"
        fi
    fi

    echo ""
    _success "Project '$domain' ready!"
    _arrow "Start services: bin/mage up"
}

cmd_project_remove() {
    local domain="${1:-}"
    [[ -z "$domain" ]] && _die "Usage: bin/mage project remove <domain>"
    require_project "$domain"

    if ! ask_yes_no "Remove project '$domain' from registry? (source code and data are kept)"; then
        exit 0
    fi

    # Remove vhost
    rm -f "${NGINX_CONF_DIR}/${domain}.conf" "${NGINX_CONF_DIR}/${domain}-ssl.conf" 2>/dev/null
    project_remove "$domain"
    _success "Project '$domain' removed from registry"
    _arrow "Source code kept in: sources/${domain}/"
}

cmd_project_enable() {
    local domain="${1:-}"
    [[ -z "$domain" ]] && _die "Usage: bin/mage project enable <domain>"
    require_project "$domain"

    local php app
    php=$(project_get "$domain" "php")
    app=$(project_get "$domain" "app")

    project_update "$domain" "enabled" "true"

    # Recreate vhost if missing
    if [[ ! -f "${NGINX_CONF_DIR}/${domain}.conf" ]]; then
        _arrow "Creating vhost for ${domain}..."
        "${SCRIPTS_DIR}/create-vhost" --domain="$domain" --app="$app" --root-dir="$domain" --php-version="$php" 2>&1 || true
    fi

    _success "Project '$domain' enabled"
    _arrow "Run 'bin/mage up' to start needed services"
}

cmd_project_disable() {
    local domain="${1:-}"
    [[ -z "$domain" ]] && _die "Usage: bin/mage project disable <domain>"
    require_project "$domain"

    project_update "$domain" "enabled" "false"

    # Remove vhost (nginx won't try to resolve the backend)
    rm -f "${NGINX_CONF_DIR}/${domain}.conf" "${NGINX_CONF_DIR}/${domain}-ssl.conf" 2>/dev/null

    # Reload nginx if running
    if is_service_running nginx 2>/dev/null; then
        dc exec nginx nginx -s reload 2>/dev/null || true
    fi

    _success "Project '$domain' disabled (vhost removed, data kept)"
}

cmd_project_info() {
    local domain="${1:-}"
    [[ -z "$domain" ]] && _die "Usage: bin/mage project info <domain>"
    require_project "$domain"

    local php app db_svc db_name search enabled
    php=$(project_get "$domain" "php")
    app=$(project_get "$domain" "app")
    db_svc=$(project_get "$domain" "db_service")
    db_name=$(project_get "$domain" "db_name")
    search=$(project_get "$domain" "search")
    enabled=$(project_get "$domain" "enabled")

    echo ""
    _header "Project: $domain"
    echo ""
    printf "  %-18s %s\n" "Domain:" "$domain"
    printf "  %-18s %s\n" "PHP:" "$php"
    printf "  %-18s %s\n" "Application:" "$app"
    printf "  %-18s %s\n" "DB Service:" "$db_svc"
    printf "  %-18s %s\n" "Database:" "$db_name"
    printf "  %-18s %s\n" "Search:" "$search"
    printf "  %-18s %s\n" "Enabled:" "$enabled"
    printf "  %-18s %s\n" "Source:" "sources/${domain}/"
    printf "  %-18s %s\n" "Vhost:" "$(test -f "${NGINX_CONF_DIR}/${domain}.conf" && echo "exists" || echo "not created")"
    printf "  %-18s %s\n" "SSL:" "$(test -f "${NGINX_CONF_DIR}/${domain}-ssl.conf" && echo "enabled" || echo "no")"

    # Service status
    echo ""
    _arrow "Service status:"
    for svc in "$php" "$db_svc" "$search" nginx redis mailpit; do
        if is_service_running "$svc" 2>/dev/null; then
            _success "  $svc: running"
        else
            _warning "  $svc: stopped"
        fi
    done
    echo ""
}

cmd_project_switch_php() {
    local domain="${1:-}" new_php="${2:-}"
    [[ -z "$domain" || -z "$new_php" ]] && _die "Usage: bin/mage project switch-php <domain> <php-version>"
    require_project "$domain"

    local old_php app
    old_php=$(project_get "$domain" "php")
    app=$(project_get "$domain" "app")

    if [[ "$old_php" == "$new_php" ]]; then
        _warning "Project '$domain' already uses $new_php"
        return
    fi

    _arrow "Switching $domain: $old_php → $new_php"

    project_update "$domain" "php" "$new_php"

    # Recreate vhost with new PHP
    if [[ -f "${NGINX_CONF_DIR}/${domain}.conf" ]]; then
        rm -f "${NGINX_CONF_DIR}/${domain}.conf"
        "${SCRIPTS_DIR}/create-vhost" --domain="$domain" --app="$app" --root-dir="$domain" --php-version="$new_php" 2>&1 || true
    fi

    _success "Project '$domain' switched to $new_php"
    _arrow "Make sure $new_php is running: bin/mage up"
}

cmd_project_switch_db() {
    local domain="${1:-}" new_db="${2:-}"
    [[ -z "$domain" || -z "$new_db" ]] && _die "Usage: bin/mage project switch-db <domain> <mysql|mysql80|mariadb>"
    require_project "$domain"
    validate_db_service "$new_db"

    local old_db old_name
    old_db=$(project_get "$domain" "db_service")
    old_name=$(project_get "$domain" "db_name")

    if [[ "$old_db" == "$new_db" ]]; then
        _warning "Project '$domain' already uses $new_db"
        return
    fi

    _arrow "Switching $domain DB: $old_db \u2192 $new_db"
    project_update "$domain" "db_service" "$new_db"

    _success "Project '$domain' now uses $new_db"
    _warning "Database '$old_name' still exists on $old_db. You may need to:"
    echo "  1. Export: bin/mage db export $domain"
    echo "  2. Create on new service: ./scripts/database create --database-name=$old_name --db-service=$new_db"
    echo "  3. Import: ./scripts/database import --source=${old_name}-*.sql --target=$old_name --db-service=$new_db"
    echo "  4. Update app/etc/env.php: change db host to '$new_db'"
    _arrow "Make sure $new_db is running: bin/mage up"
}

cmd_project_switch_search() {
    local domain="${1:-}" new_search="${2:-}"
    [[ -z "$domain" || -z "$new_search" ]] && _die "Usage: bin/mage project switch-search <domain> <opensearch|elasticsearch|none>"
    require_project "$domain"

    validate_search_service "$new_search"

    local old_search
    old_search=$(project_get "$domain" "search")

    if [[ "$old_search" == "$new_search" ]]; then
        _warning "Project '$domain' already uses $new_search"
        return
    fi

    _arrow "Switching $domain search: $old_search \u2192 $new_search"
    project_update "$domain" "search" "$new_search"

    _success "Project '$domain' now uses $new_search"
    if [[ "$new_search" != "none" ]]; then
        _arrow "Make sure $new_search is running: bin/mage up"
    fi
    if [[ "$new_search" == "opensearch" || "$new_search" == "elasticsearch" ]]; then
        _warning "Update Magento search config: bin/mage magento $domain config:set catalog/search/engine $new_search"
    fi
}

cmd_project_set_field() {
    local domain="${1:-}" field="${2:-}" value="${3:-}"
    [[ -z "$domain" || -z "$field" || -z "$value" ]] && _die "Usage: bin/mage project set <domain> <field> <value>\n\nFields: php, app, db_service, db_name, search, enabled"
    require_project "$domain"

    # Validate known fields
    case "$field" in
        php)        validate_php_version "$value" ;;
        db_service) validate_db_service "$value" ;;
        app)        [[ "$value" != @(magento1|magento2|wordpress|laravel|default) ]] && _die "Invalid app: $value" ;;
        search)     validate_search_service "$value" ;;
        redis)      validate_redis_service "$value" ;;
        db_name|enabled) ;; # no validation needed
        *)          _die "Unknown field: $field. Valid: php, app, db_service, db_name, search, enabled" ;;
    esac

    local old_value
    old_value=$(project_get "$domain" "$field")
    project_update "$domain" "$field" "$value"
    _success "$domain: $field changed from '$old_value' to '$value'"

    # If PHP changed, regenerate vhost
    if [[ "$field" == "php" && -f "${NGINX_CONF_DIR}/${domain}.conf" ]]; then
        local app
        app=$(project_get "$domain" "app")
        rm -f "${NGINX_CONF_DIR}/${domain}.conf"
        "${SCRIPTS_DIR}/create-vhost" --domain="$domain" --app="$app" --root-dir="$domain" --php-version="$value" 2>&1 || true
    fi
}

# ── Command: up (smart start) ────────────────────────────────────────────────
cmd_up() {
    local profiles=()
    local services=()
    local explicit=false

    for arg in "$@"; do
        case "$arg" in
            --profile=*) profiles+=("--profile" "${arg#*=}") ;;
            -*)          _die "Unknown option: $arg" ;;
            *)           services+=("$arg"); explicit=true ;;
        esac
    done

    if [[ "$explicit" == false ]]; then
        local proj_services proj_profiles
        proj_services=$(project_compute_services)
        proj_profiles=$(project_compute_profiles)

        if [[ -n "$proj_services" && "$proj_services" != "nginx redis mailpit" ]]; then
            _arrow "Smart start from projects.json..."
            for p in $proj_profiles; do
                profiles+=("--profile" "$p")
            done
            read -ra services <<< "$proj_services"
            _arrow "Services: ${services[*]}"
            [[ -n "$proj_profiles" ]] && _arrow "Profiles: $proj_profiles"
        else
            _arrow "No projects registered. Starting default stack..."
            _arrow "Tip: ${_bold}bin/mage project add <domain>${_reset}"
        fi
    fi

    _arrow "Starting services..."
    if [[ ${#services[@]} -gt 0 ]]; then
        dc "${profiles[@]}" up -d "${services[@]}" 2>&1
    else
        dc "${profiles[@]}" up -d 2>&1
    fi
    _success "Services started"
}

# ── Command: down/stop/restart ────────────────────────────────────────────────
cmd_down()    { _arrow "Stopping..."; dc --profile legacy --profile mysql80 --profile mariadb --profile elasticsearch down --remove-orphans; _success "Done"; }
cmd_stop()    { _arrow "Stopping..."; dc stop; _success "Done"; }
cmd_restart() { if [[ -n "${1:-}" ]]; then dc restart "$1"; else dc restart; fi; _success "Restarted"; }

# ── Command: shell (project-aware) ───────────────────────────────────────────
cmd_shell() {
    local arg="${1:-}"
    [[ -z "$arg" ]] && { _error "Usage: bin/mage shell <domain|php-version>"; exit 1; }
    local php
    php=$(resolve_php "$arg")
    validate_php_version "$php"
    require_service "$php"
    if [[ "$arg" == *"."* ]] && project_exists "$arg"; then
        dc exec --user nginx "$php" bash -c "cd /home/public_html/${arg} && exec bash"
    else
        dc exec --user nginx "$php" bash
    fi
}

# ── Command: composer (project-aware) ─────────────────────────────────────────
cmd_composer() {
    local arg="${1:-}"
    [[ -z "$arg" ]] && { _error "Usage: bin/mage composer <domain|php-version> [args...]"; exit 1; }
    local php
    php=$(resolve_php "$arg")
    validate_php_version "$php"
    require_service "$php"
    shift
    if [[ "$arg" == *"."* ]] && project_exists "$arg"; then
        dc exec --user nginx "$php" bash -c "cd /home/public_html/${arg} && composer $*"
    else
        dc exec --user nginx "$php" composer "$@"
    fi
}

# ── Command: magento (project-aware) ──────────────────────────────────────────
cmd_magento() {
    local domain="${1:-}"
    [[ -z "$domain" ]] && { _error "Usage: bin/mage magento <domain> [magento-args...]"; exit 1; }

    local php
    if project_exists "$domain"; then
        php=$(project_get "$domain" "php")
    else
        _die "Project '$domain' not found. Register it with: bin/mage project add $domain"
    fi

    validate_php_version "$php"
    require_service "$php"
    shift
    dc exec --user nginx "$php" php "/home/public_html/${domain}/bin/magento" "$@"
}

# ── Command: db (project-aware) ───────────────────────────────────────────────
cmd_db() {
    local action="${1:-}"
    [[ -z "$action" ]] && { _error "Usage: bin/mage db <list|create|drop|export|import> [args]"; exit 1; }
    shift

    case "$action" in
        list)
            local db_svc="mysql"
            for arg in "$@"; do
                case $arg in --db-service=*) db_svc="${arg#*=}" ;; esac
            done
            exec "${SCRIPTS_DIR}/database" list --db-service="$db_svc"
            ;;
        create)
            local target="${1:-}"
            [[ -z "$target" ]] && _die "Usage: bin/mage db create <domain|db_name>"
            if project_exists "$target"; then
                local db_svc db_name
                db_svc=$(project_get "$target" "db_service")
                db_name=$(project_get "$target" "db_name")
                _arrow "Project '$target': creating '${db_name}' on ${db_svc}"
                exec "${SCRIPTS_DIR}/database" create --database-name="$db_name" --db-service="$db_svc"
            else
                exec "${SCRIPTS_DIR}/database" create --database-name="$target" "${@:2}"
            fi
            ;;
        drop)
            local target="${1:-}"
            [[ -z "$target" ]] && _die "Usage: bin/mage db drop <domain|db_name>"
            if project_exists "$target"; then
                local db_svc db_name
                db_svc=$(project_get "$target" "db_service")
                db_name=$(project_get "$target" "db_name")
                _arrow "Project '$target': dropping '${db_name}' on ${db_svc}"
                exec "${SCRIPTS_DIR}/database" drop --database-name="$db_name" --db-service="$db_svc"
            else
                exec "${SCRIPTS_DIR}/database" drop --database-name="$target" "${@:2}"
            fi
            ;;
        export)
            local target="${1:-}"
            [[ -z "$target" ]] && _die "Usage: bin/mage db export <domain|db_name>"
            if project_exists "$target"; then
                local db_svc db_name
                db_svc=$(project_get "$target" "db_service")
                db_name=$(project_get "$target" "db_name")
                _arrow "Project '$target': exporting '${db_name}' from ${db_svc}"
                exec "${SCRIPTS_DIR}/database" export --database-name="$db_name" --db-service="$db_svc"
            else
                exec "${SCRIPTS_DIR}/database" export --database-name="$target" "${@:2}"
            fi
            ;;
        import)
            local target="${1:-}" source="${2:-}"
            [[ -z "$target" || -z "$source" ]] && _die "Usage: bin/mage db import <domain> <file.sql>"
            if project_exists "$target"; then
                local db_svc db_name
                db_svc=$(project_get "$target" "db_service")
                db_name=$(project_get "$target" "db_name")
                _arrow "Project '$target': importing '${source}' into '${db_name}' on ${db_svc}"
                exec "${SCRIPTS_DIR}/database" import --source="$source" --target="$db_name" --db-service="$db_svc"
            else
                _die "For non-project import, use: ./scripts/database import --source=<file> --target=<db> --db-service=<svc>"
            fi
            ;;
        *)  _die "Unknown db action: $action" ;;
    esac
}

# ── Command: vhost ────────────────────────────────────────────────────────────
cmd_vhost() {
    local domain="${1:-}" app="${2:-}" php="${3:-}"
    [[ -z "$domain" || -z "$app" || -z "$php" ]] && { _error "Usage: bin/mage vhost <domain> <app> <php>"; exit 1; }
    exec "${SCRIPTS_DIR}/create-vhost" --domain="$domain" --app="$app" --root-dir="$domain" --php-version="$php"
}

# ── Command: xdebug ──────────────────────────────────────────────────────────
cmd_xdebug() {
    local action="${1:-}" php="${2:-}"
    [[ -z "$action" ]] && { _error "Usage: bin/mage xdebug <on|off|status> <php>"; exit 1; }
    local cmd; case "$action" in on|enable) cmd="enable";; off|disable) cmd="disable";; status) cmd="status";; *) _die "Unknown: $action";; esac
    [[ -z "$php" ]] && { _error "PHP version required. Example: bin/mage xdebug $action php83"; exit 1; }
    exec "${SCRIPTS_DIR}/xdebug" "$cmd" --php-version="$php"
}

# ── Command: ssl ──────────────────────────────────────────────────────────────
cmd_ssl()     { [[ -z "${1:-}" ]] && _die "Usage: bin/mage ssl <domain>"; exec "${SCRIPTS_DIR}/ssl" --domain="$1"; }

# ── Command: varnish ──────────────────────────────────────────────────────────
cmd_varnish() {
    local action="${1:-}" domain="${2:-}"
    [[ -z "$action" ]] && { _error "Usage: bin/mage varnish <on|off|status> <domain>"; exit 1; }
    local cmd; case "$action" in on|enable) cmd="enable";; off|disable) cmd="disable";; status) cmd="status";; *) _die "Unknown: $action";; esac
    [[ -z "$domain" ]] && _die "Domain required."
    exec "${SCRIPTS_DIR}/varnish" "$cmd" --domain="$domain"
}

# ── Command: install ──────────────────────────────────────────────────────────
cmd_install() {
    local ver="${1:-}" edition="${2:-}" domain="${3:-}" php="${4:-}"
    [[ -z "$ver" || -z "$edition" || -z "$domain" || -z "$php" ]] && { _error "Usage: bin/mage install <version> <edition> <domain> <php>"; exit 1; }
    exec "${SCRIPTS_DIR}/init-magento" --magento-version="$ver" --magento-edition="$edition" --domain="$domain" --php-version="$php"
}

# ── Command: status (with projects) ──────────────────────────────────────────
cmd_status() {
    _header "Docker Magento Stack Status"

    # Projects table
    local proj_count
    proj_count=$(project_list_raw | wc -l)
    if [[ $proj_count -gt 0 ]]; then
        echo ""
        _arrow "${_bold}Registered Projects${_reset}"
        echo ""
        printf "  %-25s %-8s %-10s %-10s %s\n" "DOMAIN" "PHP" "DB" "SEARCH" "STATUS"
        printf "  %-25s %-8s %-10s %-10s %s\n" "─────────────────────────" "────────" "──────────" "──────────" "──────"
        while IFS='|' read -r domain php app db_svc db_name search enabled; do
            [[ -z "$domain" ]] && continue
            local st
            if [[ "$enabled" == "true" ]]; then st="${_green}● on${_reset}"; else st="${_red}○ off${_reset}"; fi
            printf "  %-25s %-8s %-10s %-10s %b\n" "$domain" "$php" "$db_svc" "$search" "$st"
        done < <(project_list_raw)
        echo ""
    fi

    # Running containers
    _arrow "${_bold}Running Containers${_reset}"
    echo ""
    dc ps --format "table {{.Name}}\t{{.Service}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || dc ps
    echo ""
}

# ── Command: logs ─────────────────────────────────────────────────────────────
cmd_logs() { if [[ -n "${1:-}" ]]; then dc logs -f "$1"; else dc logs -f; fi; }

# ── Command: setup ────────────────────────────────────────────────────────────
cmd_setup() {
    _print_banner
    _header "First-Time Setup"
    echo ""
    _arrow "Checking Docker..."
    command -v docker &>/dev/null || _die "Docker not installed."
    docker info &>/dev/null || _die "Docker not running."
    _success "Docker is ready"

    if [[ ! -f "${MAGE_ROOT}/.env" ]]; then
        cp "${MAGE_ROOT}/env-example" "${MAGE_ROOT}/.env"
        _success ".env created"
    else
        _success ".env exists"
    fi

    echo ""
    if ask_yes_no "Build PHP images now?"; then
        local build_legacy=false
        if ask_yes_no "Include legacy PHP 7.x?"; then build_legacy=true; fi
        if [[ "$build_legacy" == true ]]; then dc --profile legacy build; else dc build; fi
        _success "Images built"
    fi

    echo ""
    _arrow "Add your first project:"
    echo "  bin/mage project add mysite.com"
    echo ""
    _success "Setup complete! Run ${_bold}bin/mage help${_reset} for all commands."
}

# ── Main ──────────────────────────────────────────────────────────────────────
main() {
    require_root_dir
    local command="${1:-help}"
    shift 2>/dev/null || true

    case "$command" in
        up)             cmd_up "$@" ;;
        down)           cmd_down ;;
        stop)           cmd_stop ;;
        restart)        cmd_restart "$@" ;;
        status|ps)      cmd_status ;;
        logs)           cmd_logs "$@" ;;
        project|proj|p) cmd_project "$@" ;;
        shell|sh)       cmd_shell "$@" ;;
        composer)       cmd_composer "$@" ;;
        magento)        cmd_magento "$@" ;;
        db)             cmd_db "$@" ;;
        vhost)          cmd_vhost "$@" ;;
        xdebug)         cmd_xdebug "$@" ;;
        ssl)            cmd_ssl "$@" ;;
        varnish)        cmd_varnish "$@" ;;
        install)        cmd_install "$@" ;;
        setup)          cmd_setup ;;
        help|-h|--help) show_help ;;
        version|-v)     echo "mage v${MAGE_VERSION}" ;;
        *)              _error "Unknown command: $command"; echo "Run ${_bold}bin/mage help${_reset}"; exit 1 ;;
    esac
}

main "$@"
