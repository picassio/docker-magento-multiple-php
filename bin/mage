#!/usr/bin/env bash
# =============================================================================
# mage — Single CLI entrypoint for Docker Magento Multi-PHP stack
# =============================================================================
#
# Usage: bin/mage <command> [args...]
#        bin/mage help
#

# Resolve project root from bin/ directory
MAGE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$MAGE_ROOT" || exit 1

# Source shared libraries (docker.sh → common.sh)
source "${MAGE_ROOT}/scripts/lib/docker.sh"

# ── Version ───────────────────────────────────────────────────────────────────
MAGE_VERSION="1.0.0"

# ── Help ──────────────────────────────────────────────────────────────────────
show_help() {
    cat <<EOF
${_green}${_bold}mage${_reset} — Docker Magento CLI ${_blue}v${MAGE_VERSION}${_reset}

${_bold}USAGE${_reset}
    bin/mage <command> [options]

${_bold}LIFECYCLE${_reset}
    ${_green}setup${_reset}                              Interactive first-time setup
    ${_green}up${_reset} [services...]                    Start services (default: core stack)
    ${_green}down${_reset}                                Stop & remove containers
    ${_green}stop${_reset}                                Stop all services
    ${_green}restart${_reset} [service]                   Restart all or a specific service
    ${_green}status${_reset}                              Show running services & domains
    ${_green}logs${_reset} [service]                      Tail container logs

${_bold}DEVELOPMENT${_reset}
    ${_green}shell${_reset} <php>                         Open bash in PHP container
    ${_green}composer${_reset} <php> [args...]            Run composer in PHP container
    ${_green}magento${_reset} <php> <dir> [args...]       Run bin/magento in container

${_bold}DATABASE${_reset}
    ${_green}db list${_reset}                             List databases
    ${_green}db create${_reset} <name>                    Create a database
    ${_green}db drop${_reset} <name>                      Drop a database
    ${_green}db export${_reset} <name>                    Export database to SQL file
    ${_green}db import${_reset} <file.sql> <target_db>    Import SQL file into database

${_bold}HOSTING${_reset}
    ${_green}vhost${_reset} <domain> <app> <php>          Create nginx virtual host
    ${_green}ssl${_reset} <domain>                        Enable SSL for domain
    ${_green}xdebug${_reset} <on|off|status> <php>        Toggle Xdebug
    ${_green}varnish${_reset} <on|off|status> <domain>    Toggle Varnish

${_bold}INSTALL${_reset}
    ${_green}install${_reset} <ver> <edition> <domain> <php>  Install fresh Magento

${_bold}OPTIONS${_reset}
    ${_green}--profile=<name>${_reset}   Compose profile (legacy, debug, varnish, mariadb, etc.)

${_bold}EXAMPLES${_reset}
    bin/mage setup                                 # First-time setup wizard
    bin/mage up                                    # Start default stack
    bin/mage up --profile=legacy php72 nginx       # Start with legacy PHP
    bin/mage shell php83                           # Open shell in PHP 8.3
    bin/mage composer php83 install                # Run composer install
    bin/mage magento php83 mysite.com cache:flush  # Flush Magento cache
    bin/mage db create mydb                        # Create database
    bin/mage db import backup.sql mydb             # Import SQL file
    bin/mage vhost mysite.com magento2 php83       # Create virtual host
    bin/mage xdebug on php83                       # Enable Xdebug
    bin/mage install 2.4.7 community my.com php83  # Install Magento

EOF
}

# ── Command: up ───────────────────────────────────────────────────────────────
cmd_up() {
    local profiles=()
    local services=()

    for arg in "$@"; do
        case "$arg" in
            --profile=*) profiles+=("--profile" "${arg#*=}") ;;
            -*)          _die "Unknown option: $arg. Use --profile=<name> for profiles." ;;
            *)           services+=("$arg") ;;
        esac
    done

    _arrow "Starting services..."
    if [[ ${#services[@]} -gt 0 ]]; then
        dc "${profiles[@]}" up -d "${services[@]}"
    else
        dc "${profiles[@]}" up -d
    fi
    _success "Services started"
}

# ── Command: down ─────────────────────────────────────────────────────────────
cmd_down() {
    _arrow "Stopping and removing containers..."
    dc down --remove-orphans
    _success "All containers removed"
}

# ── Command: restart ──────────────────────────────────────────────────────────
cmd_restart() {
    if [[ -n "${1:-}" ]]; then
        _arrow "Restarting ${1}..."
        dc restart "$1"
        _success "${1} restarted"
    else
        _arrow "Restarting all services..."
        dc restart
        _success "All services restarted"
    fi
}

# ── Command: stop ─────────────────────────────────────────────────────────────
cmd_stop() {
    _arrow "Stopping all services..."
    dc stop
    _success "All services stopped"
}

# ── Command: shell ────────────────────────────────────────────────────────────
cmd_shell() {
    if [[ -z "${1:-}" ]]; then
        _error "Usage: bin/mage shell <php-version>"
        _arrow "Example: bin/mage shell php83"
        _arrow "Available: $(get_available_php_versions | tr '\n' ', ' | sed 's/,$//')"
        exit 1
    fi
    exec "${SCRIPTS_DIR}/shell" "$@"
}

# ── Command: db ───────────────────────────────────────────────────────────────
cmd_db() {
    local action="${1:-}"

    if [[ -z "$action" ]]; then
        _error "Usage: bin/mage db <action> [args]"
        echo ""
        _arrow "Actions: list, create, drop, export, import"
        echo ""
        echo "  bin/mage db list"
        echo "  bin/mage db create <name>"
        echo "  bin/mage db drop <name>"
        echo "  bin/mage db export <name>"
        echo "  bin/mage db import <file.sql> <target_db>"
        exit 1
    fi

    shift

    case "$action" in
        list)
            exec "${SCRIPTS_DIR}/database" list
            ;;
        create)
            local name="${1:-}"
            [[ -z "$name" ]] && _die "Usage: bin/mage db create <name>"
            exec "${SCRIPTS_DIR}/database" create --database-name="$name"
            ;;
        drop)
            local name="${1:-}"
            [[ -z "$name" ]] && _die "Usage: bin/mage db drop <name>"
            exec "${SCRIPTS_DIR}/database" drop --database-name="$name"
            ;;
        export)
            local name="${1:-}"
            [[ -z "$name" ]] && _die "Usage: bin/mage db export <name>"
            exec "${SCRIPTS_DIR}/database" export --database-name="$name"
            ;;
        import)
            local source="${1:-}"
            local target="${2:-}"
            [[ -z "$source" || -z "$target" ]] && _die "Usage: bin/mage db import <file.sql> <target_db>"
            exec "${SCRIPTS_DIR}/database" import --source="$source" --target="$target"
            ;;
        *)
            _die "Unknown db action: $action. Use: list, create, drop, export, import"
            ;;
    esac
}

# ── Command: vhost ────────────────────────────────────────────────────────────
cmd_vhost() {
    local domain="${1:-}"
    local app="${2:-}"
    local php="${3:-}"

    if [[ -z "$domain" || -z "$app" || -z "$php" ]]; then
        _error "Usage: bin/mage vhost <domain> <app-type> <php-version>"
        echo ""
        _arrow "App types: magento1, magento2, wordpress, laravel, default"
        echo ""
        echo "  bin/mage vhost mysite.com magento2 php83"
        echo "  bin/mage vhost blog.local wordpress php84"
        exit 1
    fi

    exec "${SCRIPTS_DIR}/create-vhost" \
        --domain="$domain" \
        --app="$app" \
        --root-dir="$domain" \
        --php-version="$php"
}

# ── Command: xdebug ──────────────────────────────────────────────────────────
cmd_xdebug() {
    local action="${1:-}"
    local php="${2:-}"

    if [[ -z "$action" ]]; then
        _error "Usage: bin/mage xdebug <on|off|status> <php-version>"
        echo ""
        echo "  bin/mage xdebug on php83"
        echo "  bin/mage xdebug off php83"
        echo "  bin/mage xdebug status php83"
        exit 1
    fi

    # Translate on/off to enable/disable
    local cmd
    case "$action" in
        on|enable)   cmd="enable" ;;
        off|disable) cmd="disable" ;;
        status)      cmd="status" ;;
        *)           _die "Unknown xdebug action: $action. Use: on, off, status" ;;
    esac

    if [[ -z "$php" ]]; then
        _error "PHP version required."
        _arrow "Example: bin/mage xdebug $action php83"
        _arrow "Available: $(get_available_php_versions | tr '\n' ', ' | sed 's/,$//')"
        exit 1
    fi

    exec "${SCRIPTS_DIR}/xdebug" "$cmd" --php-version="$php"
}

# ── Command: ssl ──────────────────────────────────────────────────────────────
cmd_ssl() {
    local domain="${1:-}"

    if [[ -z "$domain" ]]; then
        _error "Usage: bin/mage ssl <domain>"
        echo ""
        echo "  bin/mage ssl mysite.com"
        exit 1
    fi

    exec "${SCRIPTS_DIR}/ssl" --domain="$domain"
}

# ── Command: varnish ─────────────────────────────────────────────────────────
cmd_varnish() {
    local action="${1:-}"
    local domain="${2:-}"

    if [[ -z "$action" ]]; then
        _error "Usage: bin/mage varnish <on|off|status> <domain>"
        echo ""
        echo "  bin/mage varnish on mysite.com"
        echo "  bin/mage varnish off mysite.com"
        echo "  bin/mage varnish status mysite.com"
        exit 1
    fi

    # Translate on/off to enable/disable
    local cmd
    case "$action" in
        on|enable)   cmd="enable" ;;
        off|disable) cmd="disable" ;;
        status)      cmd="status" ;;
        *)           _die "Unknown varnish action: $action. Use: on, off, status" ;;
    esac

    if [[ -z "$domain" ]]; then
        _error "Domain required."
        _arrow "Example: bin/mage varnish $action mysite.com"
        exit 1
    fi

    exec "${SCRIPTS_DIR}/varnish" "$cmd" --domain="$domain"
}

# ── Command: composer ─────────────────────────────────────────────────────────
cmd_composer() {
    local php="${1:-}"

    if [[ -z "$php" ]]; then
        _error "Usage: bin/mage composer <php-version> [composer-args...]"
        echo ""
        echo "  bin/mage composer php83 install"
        echo "  bin/mage composer php83 require monolog/monolog"
        echo "  bin/mage composer php83 update --dry-run"
        exit 1
    fi

    validate_php_version "$php"
    require_service "$php"
    shift
    dc exec --user nginx "$php" composer "$@"
}

# ── Command: magento ──────────────────────────────────────────────────────────
cmd_magento() {
    local php="${1:-}"
    local dir="${2:-}"

    if [[ -z "$php" || -z "$dir" ]]; then
        _error "Usage: bin/mage magento <php-version> <project-dir> [magento-args...]"
        echo ""
        echo "  bin/mage magento php83 mysite.com cache:flush"
        echo "  bin/mage magento php83 mysite.com setup:upgrade"
        echo "  bin/mage magento php83 mysite.com indexer:reindex"
        exit 1
    fi

    validate_php_version "$php"
    require_service "$php"
    shift 2
    dc exec --user nginx "$php" php "/home/public_html/${dir}/bin/magento" "$@"
}

# ── Command: install ──────────────────────────────────────────────────────────
cmd_install() {
    local version="${1:-}"
    local edition="${2:-}"
    local domain="${3:-}"
    local php="${4:-}"

    if [[ -z "$version" || -z "$edition" || -z "$domain" || -z "$php" ]]; then
        _error "Usage: bin/mage install <version> <edition> <domain> <php-version>"
        echo ""
        _arrow "Editions: community, enterprise"
        echo ""
        echo "  bin/mage install 2.4.7 community mysite.com php83"
        echo "  bin/mage install 2.4.6-p4 enterprise shop.local php82"
        exit 1
    fi

    exec "${SCRIPTS_DIR}/init-magento" \
        --magento-version="$version" \
        --magento-edition="$edition" \
        --domain="$domain" \
        --php-version="$php"
}

# ── Command: status ───────────────────────────────────────────────────────────
cmd_status() {
    _header "Docker Magento Stack Status"

    echo ""
    _arrow "${_bold}Running Containers${_reset}"
    echo ""
    dc ps --format "table {{.Name}}\t{{.Service}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || dc ps
    echo ""

    # Show PHP versions
    local running_php
    running_php=$(list_running_services 2>/dev/null | grep '^php' | sort || true)
    if [[ -n "$running_php" ]]; then
        _arrow "${_bold}Active PHP Versions${_reset}"
        for svc in $running_php; do
            local ver
            ver="$(get_php_numeric_version "$svc")"
            _success "  ${svc} (PHP ${ver})"
        done
        echo ""
    fi

    # Show configured domains
    local conf_dir="${CONF_DIR}/nginx/conf.d"
    if [[ -d "$conf_dir" ]]; then
        local domain_confs
        domain_confs=$(find "$conf_dir" -maxdepth 1 -name "*.conf" ! -name "*-ssl.conf" ! -name "default.conf" -printf "%f\n" 2>/dev/null | sort || true)
        if [[ -n "$domain_confs" ]]; then
            _arrow "${_bold}Configured Domains${_reset}"
            while IFS= read -r conf; do
                local domain="${conf%.conf}"
                local has_ssl=""
                if [[ -f "${conf_dir}/${domain}-ssl.conf" ]]; then
                    has_ssl=" ${_green}[SSL]${_reset}"
                fi
                echo "    ${_blue}${domain}${_reset}${has_ssl}"
            done <<< "$domain_confs"
            echo ""
        fi
    fi
}

# ── Command: logs ─────────────────────────────────────────────────────────────
cmd_logs() {
    if [[ -n "${1:-}" ]]; then
        dc logs -f "$1"
    else
        dc logs -f
    fi
}

# ── Command: setup ────────────────────────────────────────────────────────────
cmd_setup() {
    _print_banner
    _header "First-Time Setup"
    echo ""

    # 1. Check Docker
    _arrow "Checking Docker..."
    if ! command -v docker &>/dev/null; then
        _die "Docker is not installed. Please install Docker first: https://docs.docker.com/get-docker/"
    fi
    if ! docker info &>/dev/null; then
        _die "Docker daemon is not running. Please start Docker."
    fi
    _success "Docker is ready"

    # 2. Copy .env
    if [[ ! -f "${MAGE_ROOT}/.env" ]]; then
        _arrow "Creating .env from env-example..."
        cp "${MAGE_ROOT}/env-example" "${MAGE_ROOT}/.env"
        _success ".env created — edit it to customize ports and versions"
    else
        _success ".env already exists"
    fi

    # 3. Select PHP versions
    echo ""
    _arrow "Available PHP versions:"
    echo ""

    local all_php=()
    local modern_php=()
    local legacy_php=()

    while IFS= read -r svc; do
        all_php+=("$svc")
        local ver="${svc#php}"
        local major="${ver:0:1}"
        if [[ "$major" -lt 8 ]]; then
            legacy_php+=("$svc")
        else
            modern_php+=("$svc")
        fi
    done < <(dc config --services 2>/dev/null | grep '^php' | sort)

    echo "  ${_bold}Modern (always available):${_reset}"
    for svc in "${modern_php[@]}"; do
        _success "    ${svc} (PHP $(get_php_numeric_version "$svc"))"
    done
    echo ""

    if [[ ${#legacy_php[@]} -gt 0 ]]; then
        echo "  ${_bold}Legacy (opt-in with --profile=legacy):${_reset}"
        for svc in "${legacy_php[@]}"; do
            _warning "    ${svc} (PHP $(get_php_numeric_version "$svc"))"
        done
        echo ""
    fi

    local build_legacy=false
    if [[ ${#legacy_php[@]} -gt 0 ]]; then
        if ask_yes_no "Build legacy PHP versions too? (PHP 7.x)"; then
            build_legacy=true
        fi
    fi

    # 4. Build images
    echo ""
    _arrow "Building PHP images (this may take a while on first run)..."
    echo ""

    if [[ "$build_legacy" == true ]]; then
        dc --profile legacy build
    else
        dc build
    fi
    _success "Images built"

    # 5. Start the stack
    echo ""
    _arrow "Starting the stack..."
    if [[ "$build_legacy" == true ]]; then
        dc --profile legacy up -d
    else
        dc up -d
    fi
    _success "Stack is running"

    # 6. Print summary
    echo ""
    _header "Setup Complete"
    echo ""
    echo "  ${_bold}Web${_reset}            http://localhost:${HTTP_PORT:-80}"
    echo "  ${_bold}Mailpit${_reset}        http://localhost:${MAILPIT_PORT:-8025}"
    echo "  ${_bold}RabbitMQ${_reset}       http://localhost:${RABBITMQ_MGMT_PORT:-15672}"
    echo "  ${_bold}MySQL${_reset}          localhost:${MYSQL_PORT:-3306}"
    echo "  ${_bold}Redis${_reset}          localhost:${REDIS_PORT:-6379}"
    echo "  ${_bold}OpenSearch${_reset}     http://localhost:${OPENSEARCH_PORT:-9200}"
    echo ""
    echo "  ${_bold}Next steps:${_reset}"
    echo "    1. Create a virtual host:   bin/mage vhost mysite.com magento2 php83"
    echo "    2. Install Magento:         bin/mage install 2.4.7 community mysite.com php83"
    echo "    3. Open a shell:            bin/mage shell php83"
    echo ""
    _success "Happy coding! Run ${_bold}bin/mage help${_reset} for all commands."
}

# ── Main dispatch ─────────────────────────────────────────────────────────────
main() {
    require_root_dir

    local command="${1:-help}"
    shift 2>/dev/null || true

    case "$command" in
        up)        cmd_up "$@" ;;
        down)      cmd_down ;;
        restart)   cmd_restart "$@" ;;
        stop)      cmd_stop ;;
        shell|sh)  cmd_shell "$@" ;;
        db)        cmd_db "$@" ;;
        vhost)     cmd_vhost "$@" ;;
        xdebug)    cmd_xdebug "$@" ;;
        ssl)       cmd_ssl "$@" ;;
        varnish)   cmd_varnish "$@" ;;
        composer)  cmd_composer "$@" ;;
        magento)   cmd_magento "$@" ;;
        install)   cmd_install "$@" ;;
        status|ps) cmd_status ;;
        logs)      cmd_logs "$@" ;;
        setup)     cmd_setup ;;
        help|-h|--help) show_help ;;
        version|-v|--version) echo "mage v${MAGE_VERSION}" ;;
        *)
            _error "Unknown command: $command"
            echo ""
            echo "Run ${_bold}bin/mage help${_reset} for available commands."
            exit 1
            ;;
    esac
}

main "$@"
