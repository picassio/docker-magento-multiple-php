#!/usr/bin/env bash
#
# Create nginx virtual host — supports Magento 1, Magento 2, WordPress, Laravel, default
#

source "$(dirname "$0")/lib/services.sh"

VHOST_DOMAIN=""
VHOST_ROOT_DIR=""
APP_TYPE=""
APP_PHP=""

# ── Usage ─────────────────────────────────────────────────────────────────────
_printUsage() {
    echo -n "Nginx Virtual Host Creator
Version 2.0

./scripts/$(basename "$0") [OPTION]...

    Options:
        --domain                    Domain name.
        --root-dir                  Source directory name inside sources/ folder.
        --app                       Application type (magento1|magento2|wordpress|laravel|default).
        --php-version               PHP version (e.g. php74, php81, php82, php83, php84).
                                    Run without args to see available versions.
        --debug                     Run command in debug mode.
        -h, --help                  Display this help and exit.

    Examples:
        ./scripts/$(basename "$0") --domain=mysite.com --app=magento2 --root-dir=mysite.com --php-version=php83

"
    _print_banner
    exit 1
}

# ── Arg parsing ───────────────────────────────────────────────────────────────
processArgs() {
    for arg in "$@"; do
        case $arg in
            --domain=*)      VHOST_DOMAIN="${arg#*=}" ;;
            --root-dir=*)    VHOST_ROOT_DIR="${arg#*=}" ;;
            --app=*)         APP_TYPE="${arg#*=}" ;;
            --php-version=*) APP_PHP="${arg#*=}" ;;
            --debug)         enable_debug ;;
            -h|--help)       _printUsage ;;
            *)               _printUsage ;;
        esac
    done

    validateArgs
}

validateArgs() {
    local errors=0

    if [[ -z "$VHOST_DOMAIN" ]]; then
        _error "--domain=... parameter is missing."
        errors=$((errors + 1))
    fi
    if [[ -z "$APP_TYPE" ]]; then
        _error "--app=... parameter is missing."
        errors=$((errors + 1))
    elif [[ "$APP_TYPE" != @(magento1|magento2|wordpress|laravel|default) ]]; then
        _error "Invalid --app value. Must be: magento1|magento2|wordpress|laravel|default"
        errors=$((errors + 1))
    fi
    if [[ -z "$VHOST_ROOT_DIR" ]]; then
        _error "--root-dir=... parameter is missing."
        errors=$((errors + 1))
    fi
    if [[ -z "$APP_PHP" ]]; then
        _error "--php-version=... parameter is missing."
        errors=$((errors + 1))
    fi

    if [[ $errors -gt 0 ]]; then
        exit 1
    fi

    # Remove trailing slash from root dir
    VHOST_ROOT_DIR="${VHOST_ROOT_DIR%/}"

    # Sanitize & validate domain
    if [[ "$VHOST_DOMAIN" == http* ]]; then
        VHOST_DOMAIN="$(sanitize_domain "$VHOST_DOMAIN")"
    fi
    validate_domain "$VHOST_DOMAIN"
    VHOST_DOMAIN=$(echo "$VHOST_DOMAIN" | tr '[:upper:]' '[:lower:]')

    # Validate PHP version
    validate_php_version "$APP_PHP"
}

# ── Pre-flight checks ────────────────────────────────────────────────────────
checkRootDir() {
    if [[ ! -d "${SOURCE_DIR}/${VHOST_ROOT_DIR}" ]]; then
        _warning "${SOURCE_DIR}/${VHOST_ROOT_DIR} does not exist yet."
        if ask_yes_no "Create it?"; then
            mkdir -p "${SOURCE_DIR}/${VHOST_ROOT_DIR}"
            _success "Created ${SOURCE_DIR}/${VHOST_ROOT_DIR}"
        else
            _die "Source directory required. Create it manually or use a different --root-dir."
        fi
    fi
}

# ── Vhost templates ──────────────────────────────────────────────────────────
prepareM1VhostContent() {
    local conf_file="${NGINX_CONF_DIR}/${VHOST_DOMAIN}.conf"
    cat > "$conf_file" <<M1EOF || _die "Cannot write to: ${conf_file}"
server {
    listen 80;
    server_name ${VHOST_DOMAIN};
    root /home/public_html/${VHOST_ROOT_DIR};

    location / {
        index index.html index.php;
        try_files \$uri \$uri/ @handler;
        expires 30d;
    }

    location ~ \.(js|css|png|jpg|gif|swf|ico|pdf|mov|fla|zip|rar)$ {
        try_files \$uri =404;
    }

    location /app/                { deny all; }
    location /includes/           { deny all; }
    location /lib/                { deny all; }
    location /media/downloadable/ { deny all; }
    location /pkginfo/            { deny all; }
    location /report/config.xml   { deny all; }
    location /var/                { deny all; }

    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    location @handler {
        rewrite / /index.php;
    }

    location ~ \.php/ {
        rewrite ^(.*\.php)/ \$1 last;
    }

    location ~ \.php$ {
        if (!-e \$request_filename) { rewrite / /index.php last; }
        set \$backend "${APP_PHP}:9001";
        fastcgi_pass   \$backend;
        fastcgi_index  index.php;
        fastcgi_param  SCRIPT_FILENAME  \$document_root\$fastcgi_script_name;
        fastcgi_param  MAGE_IS_DEVELOPER_MODE true;
        include        fastcgi_params;
        fastcgi_read_timeout 300;
    }
}
M1EOF
    _success "Magento 1 vhost created: ${conf_file}"
}

prepareM2VhostContent() {
    local conf_file="${NGINX_CONF_DIR}/${VHOST_DOMAIN}.conf"
    cat > "$conf_file" <<M2EOF || _die "Cannot write to: ${conf_file}"
server {
    server_name ${VHOST_DOMAIN};
    set \$MAGE_ROOT /home/public_html/${VHOST_ROOT_DIR};

    access_log /var/log/nginx/${VHOST_DOMAIN}.access.log;
    error_log /var/log/nginx/${VHOST_DOMAIN}.error.log;

    root \$MAGE_ROOT/pub;

    index index.php;
    autoindex off;
    charset UTF-8;
    error_page 404 403 = /errors/404.php;

    location /.user.ini {
        deny all;
    }

    location ~* ^/setup(\$|/) {
        root \$MAGE_ROOT;
        location ~ ^/setup/index.php {
            set \$backend "${APP_PHP}:9001";
            fastcgi_pass   \$backend;
            fastcgi_param  PHP_FLAG  "session.auto_start=off \n suhosin.session.cryptua=off";
            fastcgi_param  PHP_VALUE "memory_limit=756M \n max_execution_time=600";
            fastcgi_param  PHP_VALUE "error_log=/home/public_html/${VHOST_ROOT_DIR}/var/log/php-error.log";
            fastcgi_read_timeout 600s;
            fastcgi_connect_timeout 600s;
            fastcgi_index  index.php;
            fastcgi_param  SCRIPT_FILENAME  \$document_root\$fastcgi_script_name;
            include        fastcgi_params;
        }
        location ~ ^/setup/(?!pub/). {
            deny all;
        }
        location ~ ^/setup/pub/ {
            add_header X-Frame-Options "SAMEORIGIN";
        }
    }

    location ~* ^/update(\$|/) {
        root \$MAGE_ROOT;
        location ~ ^/update/index.php {
            fastcgi_split_path_info ^(/update/index.php)(/.+)\$;
            set \$backend "${APP_PHP}:9001";
            fastcgi_pass   \$backend;
            fastcgi_param  PHP_VALUE "error_log=/home/public_html/${VHOST_ROOT_DIR}/var/log/php-error.log";
            fastcgi_index  index.php;
            fastcgi_param  SCRIPT_FILENAME  \$document_root\$fastcgi_script_name;
            fastcgi_param  PATH_INFO        \$fastcgi_path_info;
            include        fastcgi_params;
        }
        location ~ ^/update/(?!pub/). {
            deny all;
        }
        location ~ ^/update/pub/ {
            add_header X-Frame-Options "SAMEORIGIN";
        }
    }

    location / {
        try_files \$uri \$uri/ /index.php\$is_args\$args;
    }

    location /pub/ {
        location ~ ^/pub/media/(downloadable|customer|import|custom_options|theme_customization/.*\.xml) {
            deny all;
        }
        alias \$MAGE_ROOT/pub/;
        add_header X-Frame-Options "SAMEORIGIN";
    }

    location /static/ {
        location ~ ^/static/version {
            rewrite ^/static/(version\d*/)?(.*)$ /static/\$2 last;
        }
        location ~* \.(ico|jpg|jpeg|png|gif|svg|js|css|swf|eot|ttf|otf|woff|woff2|html|json)$ {
            add_header Cache-Control "public";
            add_header X-Frame-Options "SAMEORIGIN";
            expires +1y;
            if (!-f \$request_filename) {
                rewrite ^/static/(version\d*/)?(.*)$ /static.php?resource=\$2 last;
            }
        }
        location ~* \.(zip|gz|gzip|bz2|csv|xml)$ {
            add_header Cache-Control "no-store";
            add_header X-Frame-Options "SAMEORIGIN";
            expires    off;
            if (!-f \$request_filename) {
                rewrite ^/static/(version\d*/)?(.*)$ /static.php?resource=\$2 last;
            }
        }
        if (!-f \$request_filename) {
            rewrite ^/static/(version\d*/)?(.*)$ /static.php?resource=\$2 last;
        }
        add_header X-Frame-Options "SAMEORIGIN";
    }

    location /media/ {
        try_files \$uri \$uri/ /get.php\$is_args\$args;
        location ~ ^/media/theme_customization/.*\.xml {
            deny all;
        }
        location ~* \.(ico|jpg|jpeg|png|gif|svg|js|css|swf|eot|ttf|otf|woff|woff2)$ {
            add_header Cache-Control "public";
            add_header X-Frame-Options "SAMEORIGIN";
            expires +1y;
            try_files \$uri \$uri/ /get.php\$is_args\$args;
        }
        location ~* \.(zip|gz|gzip|bz2|csv|xml)$ {
            add_header Cache-Control "no-store";
            add_header X-Frame-Options "SAMEORIGIN";
            expires    off;
            try_files \$uri \$uri/ /get.php\$is_args\$args;
        }
        add_header X-Frame-Options "SAMEORIGIN";
    }

    location /media/customer/ { deny all; }
    location /media/downloadable/ { deny all; }
    location /media/import/ { deny all; }
    location /media/custom_options/ { deny all; }

    location /errors/ {
        location ~* \.xml$ { deny all; }
    }

    location ~ ^/(index|get|static|errors/report|errors/404|errors/503|health_check)\.php$ {
        try_files \$uri =404;
        set \$backend "${APP_PHP}:9001";
        fastcgi_pass   \$backend;
        fastcgi_param  PHP_VALUE "error_log=/home/public_html/${VHOST_ROOT_DIR}/var/log/php-error.log";
        fastcgi_buffers 16 16k;
        fastcgi_buffer_size 32k;
        fastcgi_param  PHP_FLAG  "session.auto_start=off \n suhosin.session.cryptua=off";
        fastcgi_param  PHP_VALUE "memory_limit=756M \n max_execution_time=18000";
        fastcgi_read_timeout 600s;
        fastcgi_connect_timeout 600s;
        fastcgi_index  index.php;
        fastcgi_param  SCRIPT_FILENAME  \$document_root\$fastcgi_script_name;
        include        fastcgi_params;
    }

    gzip on;
    gzip_disable "msie6";
    gzip_comp_level 6;
    gzip_min_length 1100;
    gzip_buffers 16 8k;
    gzip_proxied any;
    gzip_types
        text/plain
        text/css
        text/js
        text/xml
        text/javascript
        application/javascript
        application/x-javascript
        application/json
        application/xml
        application/xml+rss
        image/svg+xml;
    gzip_vary on;

    location ~* (\.php\$|\.phtml\$|\.htaccess\$|\.git) {
        deny all;
    }
}
M2EOF
    _success "Magento 2 vhost created: ${conf_file}"
}

prepareWpVhostContent() {
    local conf_file="${NGINX_CONF_DIR}/${VHOST_DOMAIN}.conf"
    cat > "$conf_file" <<WPEOF || _die "Cannot write to: ${conf_file}"
server {
    listen 80;
    server_name ${VHOST_DOMAIN};
    root /home/public_html/${VHOST_ROOT_DIR};
    index index.php index.html;

    access_log /var/log/nginx/${VHOST_DOMAIN}.access.log;
    error_log /var/log/nginx/${VHOST_DOMAIN}.error.log;

    client_max_body_size 64m;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # WordPress permalinks
    location / {
        try_files \$uri \$uri/ /index.php?\$args;
    }

    # PHP handler
    location ~ \.php\$ {
        try_files \$uri =404;
        set \$backend "${APP_PHP}:9001";
        fastcgi_pass   \$backend;
        fastcgi_index  index.php;
        fastcgi_param  SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
        include        fastcgi_params;
        fastcgi_read_timeout 300;
        fastcgi_buffers 16 16k;
        fastcgi_buffer_size 32k;
    }

    # Static assets
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|webp|woff|woff2|ttf|eot)\$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
        log_not_found off;
        access_log off;
    }

    # Block xmlrpc.php (brute force target)
    location = /xmlrpc.php { deny all; }

    # Protect wp-config.php
    location = /wp-config.php { deny all; }

    # Deny access to hidden files (.git, .env, .htaccess)
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Deny access to sensitive WP files
    location ~* /(wp-config\.php|readme\.html|license\.txt)\$ { deny all; }

    # Uploads: deny PHP execution
    location ~* /wp-content/uploads/.*\.php\$ { deny all; }

    # Gzip
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml image/svg+xml;
    gzip_vary on;
}
WPEOF
    _success "WordPress vhost created: ${conf_file}"
}

prepareLaravelVhostContent() {
    local conf_file="${NGINX_CONF_DIR}/${VHOST_DOMAIN}.conf"
    cat > "$conf_file" <<LAEOF || _die "Cannot write to: ${conf_file}"
server {
    listen 80;
    server_name ${VHOST_DOMAIN};
    root /home/public_html/${VHOST_ROOT_DIR};
    index index.php index.html;

    access_log /var/log/nginx/${VHOST_DOMAIN}.access.log;
    error_log /var/log/nginx/${VHOST_DOMAIN}.error.log;

    client_max_body_size 64m;
    charset utf-8;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # Laravel routes
    location / {
        try_files \$uri \$uri/ /index.php?\$query_string;
    }

    # PHP handler
    location ~ \.php\$ {
        try_files \$uri =404;
        fastcgi_split_path_info ^(.+\.php)(/.+)\$;
        set \$backend "${APP_PHP}:9001";
        fastcgi_pass   \$backend;
        fastcgi_index  index.php;
        fastcgi_param  SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
        include        fastcgi_params;
        fastcgi_read_timeout 300;
        fastcgi_buffers 16 16k;
        fastcgi_buffer_size 32k;
    }

    # Static assets
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|webp|woff|woff2|ttf|eot)\$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
        log_not_found off;
        access_log off;
    }

    # Laravel storage — deny direct access
    location ~ ^/storage/ { deny all; }

    # Deny dotfiles (.env, .git, etc.)
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Gzip
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml image/svg+xml;
    gzip_vary on;
}
LAEOF
    _success "Laravel vhost created: ${conf_file}"
}

prepareDefaultVhostContent() {
    local conf_file="${NGINX_CONF_DIR}/${VHOST_DOMAIN}.conf"
    cat > "$conf_file" <<DEFEOF || _die "Cannot write to: ${conf_file}"
server {
    listen 80;

    access_log /var/log/nginx/${VHOST_DOMAIN}.access.log;
    error_log /var/log/nginx/${VHOST_DOMAIN}.error.log;

    root /home/public_html/${VHOST_ROOT_DIR};
    index index.html index.htm;
    server_name ${VHOST_DOMAIN};

    location / {
        try_files \$uri \$uri/ =404;
    }
}
DEFEOF
    _success "Default vhost created: ${conf_file}"
}

# ── Main ──────────────────────────────────────────────────────────────────────
main() {
    require_root_dir
    [[ $# -lt 1 ]] && _printUsage

    processArgs "$@"

    require_service nginx
    require_service "$APP_PHP"
    checkRootDir

    _arrow "Creating virtual host for ${VHOST_DOMAIN} (${APP_TYPE})..."

    case "$APP_TYPE" in
        magento1) prepareM1VhostContent      ;;
        magento2) prepareM2VhostContent      ;;
        wordpress) prepareWpVhostContent     ;;
        laravel) prepareLaravelVhostContent  ;;
        default) prepareDefaultVhostContent  ;;
    esac

    add_etc_hosts "$VHOST_DOMAIN"
    reload_nginx

    _success "Virtual host created!"
    echo "################################################################"
    echo ""
    echo " >> Domain               : ${VHOST_DOMAIN}"
    echo " >> Application          : ${APP_TYPE}"
    echo " >> PHP version          : ${APP_PHP}"
    echo " >> Document Root        : ${SOURCE_DIR}/${VHOST_ROOT_DIR}"
    echo " >> Nginx Config         : ${NGINX_CONF_DIR}/${VHOST_DOMAIN}.conf"
    echo ""
    echo "################################################################"
}

main "$@"
