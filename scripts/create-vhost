#!/usr/bin/env bash
#
# Virtual Host Creation Script
# Create Nginx virtual hosts for different application types
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

source "${SCRIPT_DIR}/lib/common.sh"

shopt -s extglob

################################################################################
# CONSTANTS
################################################################################

readonly VERSION="1.2.0"
readonly VALID_APP_TYPES="magento1 magento2 wordpress laravel default"
readonly VALID_PHP_VERSIONS="php70 php71 php72 php73 php74 php74-c2 php81-c2 php82"

################################################################################
# GLOBAL VARIABLES
################################################################################

VHOST_DOMAIN=""
VHOST_ROOT_DIR=""
APP_TYPE=""
APP_PHP=""
NGINX_SITES_CONF_D=""
NGINX_SITES_CONF_D_FILE=""

################################################################################
# FUNCTIONS
################################################################################

printUsage() {
    cat <<EOF
Nginx Virtual Host Creator
Version $VERSION

./scripts/$(basename "$0") [OPTIONS]...

Options:
    --domain                    Domain name (e.g., example.com)
    --root-dir                  Application root directory
    --app                       Application type (${VALID_APP_TYPES// /|})
    --php-version               PHP version (${VALID_PHP_VERSIONS// /|})
    -h, --help                  Display this help

Examples:
    ./scripts/$(basename "$0") --domain=test.local --app=magento2 --root-dir=mysite --php-version=php74
EOF
    _printPoweredBy
    exit 1
}

processArgs() {
    for arg in "$@"; do
        case "$arg" in
            --domain=*)
                VHOST_DOMAIN="${arg#*=}"
                ;;
            --root-dir=*)
                VHOST_ROOT_DIR="${arg#*=}"
                ;;
            --app=*)
                APP_TYPE="${arg#*=}"
                ;;
            --php-version=*)
                APP_PHP="${arg#*=}"
                ;;
            -h|--help)
                printUsage
                ;;
            *)
                _error "Unknown option: $arg"
                printUsage
                ;;
        esac
    done

    validateArgs
    sanitizeArgs
}

validateArgs() {
    local error_count=0

    if [[ -z "$VHOST_DOMAIN" ]]; then
        _error "--domain parameter is required"
        ((error_count++))
    fi

    if [[ -z "$APP_TYPE" ]]; then
        _error "--app parameter is required"
        ((error_count++))
    elif [[ ! " $VALID_APP_TYPES " =~ " $APP_TYPE " ]]; then
        _error "Invalid app type: $APP_TYPE. Valid types: $VALID_APP_TYPES"
        ((error_count++))
    fi

    if [[ -z "$VHOST_ROOT_DIR" ]]; then
        _error "--root-dir parameter is required"
        ((error_count++))
    fi

    if [[ -z "$APP_PHP" ]]; then
        _error "--php-version parameter is required"
        ((error_count++))
    elif [[ ! " $VALID_PHP_VERSIONS " =~ " $APP_PHP " ]]; then
        _error "Invalid PHP version: $APP_PHP. Valid versions: $VALID_PHP_VERSIONS"
        ((error_count++))
    fi

    [[ "$error_count" -gt 0 ]] && exit 1
}

sanitizeArgs() {
    VHOST_ROOT_DIR="${VHOST_ROOT_DIR%/}"
    VHOST_DOMAIN=$(echo "$VHOST_DOMAIN" | tr '[:upper:]' '[:lower:]')

    # Validate domain pattern
    local domain_pattern="^([[:alnum:]]([[:alnum:]\-]{0,61}[[:alnum:]])?\.)+[[:alpha:]]{2,6}$"
    if [[ ! "$VHOST_DOMAIN" =~ $domain_pattern ]]; then
        _error "Invalid domain name: $VHOST_DOMAIN"
        exit 1
    fi
}

initDefaultArgs() {
    NGINX_SITES_CONF_D="${PROJECT_ROOT}/conf/nginx/conf.d"
    NGINX_SITES_CONF_D_FILE="${NGINX_SITES_CONF_D}/${VHOST_DOMAIN}.conf"
    initYesNoPrompt
}

checkContainersRunning() {
    _arrow "Checking if ${APP_PHP} container is running..."
    if isServiceRunning "${APP_PHP}"; then
        _success "${APP_PHP} container is running"
    else
        _error "${APP_PHP} container is not running"
        exit 1
    fi

    _arrow "Checking if Nginx container is running..."
    if isServiceRunning "nginx"; then
        _success "Nginx container is running"
    else
        _error "Nginx container is not running"
        exit 1
    fi
}

checkRootDir() {
    local sources_dir="${PROJECT_ROOT}/sources/${VHOST_ROOT_DIR}"

    if [[ ! -d "$sources_dir" ]]; then
        _warning "Directory does not exist: $sources_dir"
        if askYesOrNo "Create it?"; then
            _arrow "Creating directory..."
            mkdir -p "$sources_dir"
            _success "Directory created"
        else
            _error "Please create the directory first"
            exit 1
        fi
    fi
}

createVirtualHost() {
    _arrow "Creating virtual host configuration..."

    local template_file="${SCRIPT_DIR}/templates/nginx/${APP_TYPE}.conf.template"

    if [[ ! -f "$template_file" ]]; then
        _error "Template not found for app type: $APP_TYPE"
        exit 1
    fi

    # Generate vhost config from template
    sed -e "s|__DOMAIN__|${VHOST_DOMAIN}|g" \
        -e "s|__ROOT_DIR__|${VHOST_ROOT_DIR}|g" \
        -e "s|__PHP_VERSION__|${APP_PHP}|g" \
        "$template_file" > "$NGINX_SITES_CONF_D_FILE"

    _success "Virtual host configuration created"
}

createEtcHostEntry() {
    _arrow "Adding entry to /etc/hosts..."

    if grep -Eq "127.0.0.1[[:space:]]+${VHOST_DOMAIN}" /etc/hosts; then
        _warning "Entry already exists in /etc/hosts"
    else
        echo "127.0.0.1  ${VHOST_DOMAIN}" | sudo tee -a /etc/hosts >/dev/null
        _success "Added to /etc/hosts"
    fi
}

printSuccessMessage() {
    echo ""
    echo "################################################################"
    echo ""
    echo " >> Domain               : ${VHOST_DOMAIN}"
    echo " >> Application          : ${APP_TYPE}"
    echo " >> PHP version          : ${APP_PHP}"
    echo " >> Document Root        : ${PROJECT_ROOT}/sources/${VHOST_ROOT_DIR}"
    echo " >> Nginx Config File    : ${NGINX_SITES_CONF_D_FILE}"
    echo ""
    echo "################################################################"
}

################################################################################
# MAIN
################################################################################

main() {
    checkCmdDependencies

    [[ $# -lt 1 ]] && printUsage

    processArgs "$@"
    initDefaultArgs
    checkContainersRunning
    checkRootDir
    createVirtualHost
    createEtcHostEntry
    reloadNginx

    _success "Virtual host created successfully"
    printSuccessMessage
    exit 0
}

main "$@"
