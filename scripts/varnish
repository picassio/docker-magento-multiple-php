#!/usr/bin/env bash
#
# Varnish Cache Management Script
# Enable, disable, and check Varnish cache for Magento domains
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

source "${SCRIPT_DIR}/lib/common.sh"

shopt -s extglob

################################################################################
# CONSTANTS
################################################################################

readonly VERSION="1.0.0"

################################################################################
# GLOBAL VARIABLES
################################################################################

COMMAND=""
VHOST_DOMAIN=""
DOMAIN_PHP_VERSION=""
DOC_ROOT=""
NGINX_SITES_CONF_D=""
FPC_STATUS=""
NGINX_VARNISH_STATUS=0

################################################################################
# FUNCTIONS
################################################################################

printUsage() {
    cat <<EOF
Varnish Cache Management Tool
Version $VERSION

./scripts/$(basename "$0") [COMMAND] [OPTIONS]...

Commands:
    enable                    Enable Varnish cache
    disable                   Disable Varnish cache
    status                    Check Varnish status

Options:
    --domain                  Domain name (e.g., example.com)
    -h, --help                Display this help

Examples:
    ./scripts/$(basename "$0") enable --domain=test.local
    ./scripts/$(basename "$0") disable --domain=test.local
    ./scripts/$(basename "$0") status --domain=test.local
EOF
    _printPoweredBy
    exit 1
}

processArgs() {
    [[ $# -lt 1 ]] && printUsage

    case "$1" in
        enable|disable|status)
            COMMAND="$1"
            shift
            ;;
        -h|--help)
            printUsage
            ;;
        *)
            _error "Unknown command: $1"
            printUsage
            ;;
    esac

    for arg in "$@"; do
        case "$arg" in
            --domain=*)
                VHOST_DOMAIN="${arg#*=}"
                ;;
            -h|--help)
                printUsage
                ;;
            *)
                _error "Unknown option: $arg"
                printUsage
                ;;
        esac
    done

    validateArgs
}

validateArgs() {
    if [[ -z "$VHOST_DOMAIN" ]]; then
        _error "--domain parameter is required"
        exit 1
    fi
}

initDefaultArgs() {
    NGINX_SITES_CONF_D="${PROJECT_ROOT}/conf/nginx/conf.d"
    initYesNoPrompt
}

checkDomainExists() {
    _arrow "Checking if domain exists..."
    
    if [[ -f "${NGINX_SITES_CONF_D}/${VHOST_DOMAIN}.conf" ]]; then
        _success "Domain configuration exists"
    else
        _error "Domain not found: ${VHOST_DOMAIN}"
        exit 1
    fi
}

checkDomainSslExists() {
    _arrow "Checking if SSL is configured..."
    
    if [[ -f "${NGINX_SITES_CONF_D}/${VHOST_DOMAIN}-ssl.conf" ]]; then
        _success "SSL configuration exists"
    else
        _error "SSL not configured for ${VHOST_DOMAIN}"
        _error "Enable SSL first with: ./scripts/ssl --domain=${VHOST_DOMAIN}"
        exit 1
    fi
}

getDomainDocroot() {
    _arrow "Getting domain document root..."
    
    DOC_ROOT=$(grep "/home/public_html/" "${NGINX_SITES_CONF_D}/${VHOST_DOMAIN}.conf" | \
        grep -v "fastcgi_param" | awk '{print $3}' | awk -F/ '{print $4}' | awk -F\; '{print $1}' | head -1)
    
    if [[ -z "$DOC_ROOT" ]]; then
        _error "Could not determine document root"
        exit 1
    fi
    
    _success "Document root: $DOC_ROOT"
}

getDomainPhpVersion() {
    _arrow "Getting PHP version..."
    
    DOMAIN_PHP_VERSION=$(grep 9001 "${NGINX_SITES_CONF_D}/${VHOST_DOMAIN}.conf" | \
        awk 'NR==1{print $2}' | awk -F: '{print $1}')
    
    if [[ -z "$DOMAIN_PHP_VERSION" ]]; then
        _error "Could not determine PHP version"
        exit 1
    fi
    
    _success "PHP version: $DOMAIN_PHP_VERSION"
}

checkContainersRunning() {
    for service in nginx mysql "$DOMAIN_PHP_VERSION"; do
        _arrow "Checking if $service is running..."
        if isServiceRunning "$service"; then
            _success "$service is running"
        else
            _error "$service is not running"
            exit 1
        fi
    done
}

checkMagentoFpcStatus() {
    FPC_STATUS=$(docker-compose exec -T --user nginx "$DOMAIN_PHP_VERSION" \
        php "/home/public_html/${DOC_ROOT}/bin/magento" config:show system/full_page_cache/caching_application 2>&1 || echo "0")
    FPC_STATUS=${FPC_STATUS%$'\r'}
}

checkNginxVarnishProxyPass() {
    if grep -q 'proxy_pass http://varnish:6081' "${NGINX_SITES_CONF_D}/${VHOST_DOMAIN}-ssl.conf"; then
        NGINX_VARNISH_STATUS=1
    else
        NGINX_VARNISH_STATUS=0
    fi
}

enableVarnish() {
    checkMagentoFpcStatus
    
    if [[ "$FPC_STATUS" != "2" ]]; then
        _arrow "Configuring Varnish in Magento..."
        docker-compose exec -T --user nginx "$DOMAIN_PHP_VERSION" \
            php "/home/public_html/${DOC_ROOT}/bin/magento" config:set system/full_page_cache/caching_application 2
        
        docker-compose exec -T --user nginx "$DOMAIN_PHP_VERSION" \
            php "/home/public_html/${DOC_ROOT}/bin/magento" setup:config:set --http-cache-hosts=varnish:6081
        
        docker-compose exec -T --user nginx "$DOMAIN_PHP_VERSION" \
            php "/home/public_html/${DOC_ROOT}/bin/magento" cache:flush
        
        _success "Varnish configured in Magento"
    fi

    checkNginxVarnishProxyPass
    
    if [[ $NGINX_VARNISH_STATUS -eq 0 ]]; then
        _arrow "Updating Nginx configuration..."
        sed -i 's|proxy_pass http://127.0.0.1:80;|proxy_pass http://varnish:6081;|g' \
            "${NGINX_SITES_CONF_D}/${VHOST_DOMAIN}-ssl.conf"
        reloadNginx
    fi

    _success "Varnish enabled successfully for ${VHOST_DOMAIN}"
}

disableVarnish() {
    checkMagentoFpcStatus
    
    if [[ "$FPC_STATUS" == "2" ]]; then
        _arrow "Disabling Varnish in Magento..."
        docker-compose exec -T --user nginx "$DOMAIN_PHP_VERSION" \
            php "/home/public_html/${DOC_ROOT}/bin/magento" config:set system/full_page_cache/caching_application 1
        
        docker-compose exec -T --user nginx "$DOMAIN_PHP_VERSION" \
            php "/home/public_html/${DOC_ROOT}/bin/magento" cache:flush
        
        _success "Varnish disabled in Magento"
    fi

    checkNginxVarnishProxyPass
    
    if [[ $NGINX_VARNISH_STATUS -eq 1 ]]; then
        _arrow "Updating Nginx configuration..."
        sed -i 's|proxy_pass http://varnish:6081;|proxy_pass http://127.0.0.1:80;|g' \
            "${NGINX_SITES_CONF_D}/${VHOST_DOMAIN}-ssl.conf"
        reloadNginx
    fi

    _success "Varnish disabled successfully for ${VHOST_DOMAIN}"
}

statusVarnish() {
    _arrow "Checking Varnish status..."
    checkMagentoFpcStatus
    checkNginxVarnishProxyPass
    
    if [[ "$FPC_STATUS" == "2" ]] && [[ $NGINX_VARNISH_STATUS -eq 1 ]]; then
        _success "Varnish is fully enabled"
    else
        _warning "Varnish configuration is incomplete"
        echo "  Magento FPC Status: $FPC_STATUS (2 = Varnish)"
        echo "  Nginx Proxy Status: $NGINX_VARNISH_STATUS (1 = Enabled)"
    fi
}

executeCommand() {
    case "$COMMAND" in
        enable)
            enableVarnish
            ;;
        disable)
            disableVarnish
            ;;
        status)
            statusVarnish
            ;;
    esac
}

################################################################################
# MAIN
################################################################################

main() {
    checkCmdDependencies
    processArgs "$@"
    initDefaultArgs
    checkDomainExists
    checkDomainSslExists
    getDomainDocroot
    getDomainPhpVersion
    checkContainersRunning
    executeCommand
    _success "Operation completed successfully"
    exit 0
}

main "$@"
