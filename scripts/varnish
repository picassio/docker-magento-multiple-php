#!/usr/bin/env bash
#
# Varnish management — enable/disable/status for a domain
#

source "$(dirname "$0")/lib/services.sh"

VHOST_DOMAIN=""
COMMAND=""

# ── Usage ─────────────────────────────────────────────────────────────────────
_printUsage() {
    echo -n "Docker Varnish tools
Version 2.0

./scripts/$(basename "$0") [OPT] [ARG]...

    Options:
        enable                    Enable Varnish for a domain.
        disable                   Disable Varnish for a domain.
        status                    Check Varnish status for a domain.
    Args:
        --domain                  Domain name (eg: test.com).
        -h, --help                Display this help and exit.

    Examples:
      Enable Varnish for domain test.com
        ./scripts/$(basename "$0") enable --domain=test.com
      Disable Varnish for domain test.com
        ./scripts/$(basename "$0") disable --domain=test.com
      Check Varnish status for domain test.com
        ./scripts/$(basename "$0") status --domain=test.com
"
    _print_banner
    exit 1
}

# ── Arg parsing ───────────────────────────────────────────────────────────────
processArgs() {
    case "${1:-}" in
        enable|disable|status)
            COMMAND="$1"
            for arg in "${@:2}"; do
                case $arg in
                    --domain=*) VHOST_DOMAIN="${arg#*=}" ;;
                    --debug)    enable_debug ;;
                    -h|--help)  _printUsage ;;
                    *)          _printUsage ;;
                esac
            done
            ;;
        -h|--help) _printUsage ;;
        *)         _printUsage ;;
    esac

    if [[ -z "$VHOST_DOMAIN" ]]; then
        _error "--domain=... parameter is missing."
        exit 1
    fi

    VHOST_DOMAIN="$(sanitize_domain "$VHOST_DOMAIN")"
}

# ── Varnish checks ───────────────────────────────────────────────────────────
checkFpcStatus() {
    local php_ver="$1" docroot="$2"
    local status
    status=$(dc exec --user nginx "$php_ver" php "/home/public_html/${docroot}/bin/magento" \
        config:show system/full_page_cache/caching_application 2>&1 || true)
    status="${status%$'\r'}"
    echo "$status"
}

checkNginxVarnishProxy() {
    local domain="$1"
    grep -q 'proxy_pass http://varnish:6081' "${NGINX_CONF_DIR}/${domain}-ssl.conf" 2>/dev/null
}

# ── Operations ────────────────────────────────────────────────────────────────
enableVarnish() {
    local php_ver docroot fpc_status
    php_ver="$(get_domain_php_version "$VHOST_DOMAIN")"
    docroot="$(get_domain_docroot "$VHOST_DOMAIN")"

    require_service "$php_ver"
    require_service mysql

    # Configure Magento FPC
    fpc_status="$(checkFpcStatus "$php_ver" "$docroot")"
    if [[ "$fpc_status" != "2" ]]; then
        _arrow "Setting Varnish as full page cache for ${VHOST_DOMAIN}..."
        dc exec --user nginx "$php_ver" php "/home/public_html/${docroot}/bin/magento" \
            config:set system/full_page_cache/caching_application 2 \
            || _die "Cannot configure Varnish FPC"

        _arrow "Configuring Magento env.php with Varnish host..."
        dc exec --user nginx "$php_ver" php "/home/public_html/${docroot}/bin/magento" \
            setup:config:set --http-cache-hosts=varnish:6081 \
            || _die "Cannot configure Varnish in env.php"
        _success "Magento FPC set to Varnish"

        _arrow "Flushing Magento cache..."
        dc exec --user nginx "$php_ver" php "/home/public_html/${docroot}/bin/magento" cache:flush \
            || _die "Cannot flush cache"
        _success "Cache flushed"
    else
        _success "Magento FPC already set to Varnish"
    fi

    # Configure nginx SSL proxy
    if ! checkNginxVarnishProxy "$VHOST_DOMAIN"; then
        _arrow "Updating nginx SSL config to proxy through Varnish..."
        sed -i 's|proxy_pass http://127.0.0.1:80;|proxy_pass http://varnish:6081;|g' \
            "${NGINX_CONF_DIR}/${VHOST_DOMAIN}-ssl.conf" \
            || _die "Cannot update nginx SSL config"
        reload_nginx
    else
        _success "Nginx SSL already proxying to Varnish"
    fi

    _success "Varnish enabled for ${VHOST_DOMAIN}"
    _note "Make sure your Magento base_url uses https if not already."
}

disableVarnish() {
    local php_ver docroot fpc_status
    php_ver="$(get_domain_php_version "$VHOST_DOMAIN")"
    docroot="$(get_domain_docroot "$VHOST_DOMAIN")"

    require_service "$php_ver"
    require_service mysql

    # Revert Magento FPC to built-in
    fpc_status="$(checkFpcStatus "$php_ver" "$docroot")"
    if [[ "$fpc_status" == "2" ]]; then
        _arrow "Switching Magento back to built-in cache..."
        dc exec --user nginx "$php_ver" php "/home/public_html/${docroot}/bin/magento" \
            config:set system/full_page_cache/caching_application 1 \
            || _die "Cannot disable Varnish FPC"
        _success "Magento FPC set to built-in"
        _warning "You may need to manually remove Varnish config from env.php"

        _arrow "Flushing Magento cache..."
        dc exec --user nginx "$php_ver" php "/home/public_html/${docroot}/bin/magento" cache:flush \
            || _die "Cannot flush cache"
        _success "Cache flushed"
    else
        _success "Magento FPC already using built-in cache"
    fi

    # Revert nginx SSL proxy
    if checkNginxVarnishProxy "$VHOST_DOMAIN"; then
        _arrow "Reverting nginx SSL config to direct proxy..."
        sed -i 's|proxy_pass http://varnish:6081;|proxy_pass http://127.0.0.1:80;|g' \
            "${NGINX_CONF_DIR}/${VHOST_DOMAIN}-ssl.conf" \
            || _die "Cannot update nginx SSL config"
        reload_nginx
    else
        _success "Nginx SSL already using direct proxy"
    fi

    _success "Varnish disabled for ${VHOST_DOMAIN}"
}

statusVarnish() {
    local php_ver docroot fpc_status
    php_ver="$(get_domain_php_version "$VHOST_DOMAIN")"
    docroot="$(get_domain_docroot "$VHOST_DOMAIN")"

    require_service "$php_ver"

    _arrow "Varnish status for ${VHOST_DOMAIN}:"
    echo ""

    fpc_status="$(checkFpcStatus "$php_ver" "$docroot")"
    if [[ "$fpc_status" == "2" ]]; then
        _success "Magento FPC: Varnish"
    else
        _warning "Magento FPC: Built-in (not Varnish)"
    fi

    if checkNginxVarnishProxy "$VHOST_DOMAIN"; then
        _success "Nginx SSL: Proxying through Varnish"
    else
        _warning "Nginx SSL: Direct proxy (not Varnish)"
    fi
}

# ── Main ──────────────────────────────────────────────────────────────────────
main() {
    require_root_dir
    [[ $# -lt 1 ]] && _printUsage

    processArgs "$@"
    require_service nginx
    require_domain_config "$VHOST_DOMAIN"
    require_domain_ssl "$VHOST_DOMAIN"

    case "$COMMAND" in
        enable)  enableVarnish  ;;
        disable) disableVarnish ;;
        status)  statusVarnish  ;;
    esac

    _success "Done!"
}

main "$@"
