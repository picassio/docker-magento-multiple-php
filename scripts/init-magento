#!/usr/bin/env bash
#
# Magento Installation Script
# Automated Magento installation from scratch
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

source "${SCRIPT_DIR}/lib/common.sh"

shopt -s extglob

################################################################################
# CONSTANTS
################################################################################

readonly VERSION="1.0.0"
readonly VALID_PHP_VERSIONS="php70 php71 php72 php73 php74 php74-c2 php81-c2 php82"
readonly VALID_EDITIONS="community enterprise"
readonly ADMIN_USER="admin"
readonly ADMIN_PASSWORD="Admin123"
readonly MYSQL_HOST="mysql"

################################################################################
# GLOBAL VARIABLES
################################################################################

VHOST_DOMAIN=""
MAGENTO_VERSION=""
MAGENTO_EDITION=""
APP_PHP=""
DATABASE_NAME=""
SOURCE_DIR=""
SCRIPTS_DIR=""
rootPass=""

################################################################################
# FUNCTIONS
################################################################################

printUsage() {
    cat <<EOF
Magento Installation Tool
Version $VERSION

./scripts/$(basename "$0") [OPTIONS]...

Options:
    --domain                  Domain name (e.g., magento.local)
    --magento-version         Magento version (e.g., 2.4.6)
    --magento-edition         Edition (community|enterprise)
    --php-version             PHP version (${VALID_PHP_VERSIONS// /|})
    -h, --help                Display this help

Examples:
    ./scripts/$(basename "$0") --domain=test.local --magento-version=2.4.6 --magento-edition=community --php-version=php81-c2
EOF
    _printPoweredBy
    exit 1
}

processArgs() {
    for arg in "$@"; do
        case "$arg" in
            --domain=*)
                VHOST_DOMAIN="${arg#*=}"
                ;;
            --magento-version=*)
                MAGENTO_VERSION="${arg#*=}"
                ;;
            --magento-edition=*)
                MAGENTO_EDITION="${arg#*=}"
                ;;
            --php-version=*)
                APP_PHP="${arg#*=}"
                ;;
            -h|--help)
                printUsage
                ;;
            *)
                _error "Unknown option: $arg"
                printUsage
                ;;
        esac
    done

    validateArgs
}

validateArgs() {
    local error_count=0

    if [[ -z "$VHOST_DOMAIN" ]]; then
        _error "--domain parameter is required"
        ((error_count++))
    fi

    if [[ -z "$MAGENTO_VERSION" ]]; then
        _error "--magento-version parameter is required"
        ((error_count++))
    fi

    if [[ -z "$MAGENTO_EDITION" ]]; then
        _error "--magento-edition parameter is required"
        ((error_count++))
    elif [[ ! " $VALID_EDITIONS " =~ " $MAGENTO_EDITION " ]]; then
        _error "Invalid edition: $MAGENTO_EDITION. Valid: $VALID_EDITIONS"
        ((error_count++))
    fi

    if [[ -z "$APP_PHP" ]]; then
        _error "--php-version parameter is required"
        ((error_count++))
    elif [[ ! " $VALID_PHP_VERSIONS " =~ " $APP_PHP " ]]; then
        _error "Invalid PHP version: $APP_PHP"
        ((error_count++))
    fi

    [[ "$error_count" -gt 0 ]] && exit 1
}

initDefaultArgs() {
    SCRIPTS_DIR="${SCRIPT_DIR}"
    SOURCE_DIR="${PROJECT_ROOT}/sources"
    DATABASE_NAME="magento_$(date +%s)"
    initYesNoPrompt
}

validateMagentoVersion() {
    _arrow "Validating Magento version compatibility..."

    if [[ $MAGENTO_VERSION == 2.4.@(0|1|2|3)* ]]; then
        if [[ $APP_PHP != "php74" ]]; then
            _error "Magento $MAGENTO_VERSION requires PHP 7.4"
            exit 1
        fi
        if ! isServiceRunning "elasticsearch"; then
            _error "Elasticsearch is required for Magento $MAGENTO_VERSION"
            exit 1
        fi
    elif [[ $MAGENTO_VERSION == 2.4* ]]; then
        if [[ ! " php81-c2 php82 " =~ " $APP_PHP " ]]; then
            _error "Magento $MAGENTO_VERSION requires PHP 8.1+ with Composer 2"
            exit 1
        fi
        if ! isServiceRunning "elasticsearch"; then
            _error "Elasticsearch is required for Magento 2.4.x"
            exit 1
        fi
    fi

    _success "Version compatibility validated"
}

validateBaseServices() {
    _arrow "Validating required services..."

    for service in nginx mysql "$APP_PHP"; do
        if ! isServiceRunning "$service"; then
            _error "$service is not running. Start with: docker-compose up -d $service"
            exit 1
        fi
    done

    _success "All required services are running"
}

createSourceCodeFolder() {
    _arrow "Creating source code directory..."

    if [[ -d "${SOURCE_DIR}/${VHOST_DOMAIN}" ]] && [[ -n "$(ls -A "${SOURCE_DIR}/${VHOST_DOMAIN}" 2>/dev/null)" ]]; then
        _error "Directory not empty: ${SOURCE_DIR}/${VHOST_DOMAIN}"
        exit 1
    fi

    mkdir -p "${SOURCE_DIR}/${VHOST_DOMAIN}"
    _success "Source directory created"
}

createMagentoDomain() {
    _arrow "Creating virtual host..."
    "${SCRIPTS_DIR}/create-vhost" --domain="${VHOST_DOMAIN}" --app=magento2 \
        --root-dir="${VHOST_DOMAIN}" --php-version="${APP_PHP}"
}

createDomainDatabase() {
    _arrow "Creating database..."
    "${SCRIPTS_DIR}/database" create --database-name="${DATABASE_NAME}"
}

checkComposerAuth() {
    _arrow "Checking Composer authentication..."

    local public_key private_key
    public_key="$(docker-compose exec -T --user nginx ${APP_PHP} composer config --global http-basic.repo.magento.com.username 2>/dev/null || true)"
    private_key="$(docker-compose exec -T --user nginx ${APP_PHP} composer config --global http-basic.repo.magento.com.password 2>/dev/null || true)"

    if [[ -z "$public_key" ]] || [[ -z "$private_key" ]]; then
        echo ""
        echo "Composer authentication required for repo.magento.com"
        read -r -p "    Public Key: " public_key
        read -r -p "    Private Key: " private_key
        echo ""

        docker-compose exec -T --user nginx ${APP_PHP} composer config --global \
            http-basic.repo.magento.com "${public_key}" "${private_key}"

        _success "Composer authentication configured"
    fi
}

downloadMagento() {
    _arrow "Downloading Magento ${MAGENTO_EDITION} ${MAGENTO_VERSION}..."

    docker-compose exec --user nginx ${APP_PHP} php -d memory_limit=-1 /usr/bin/composer \
        create-project --repository=https://repo.magento.com/ \
        magento/project-"${MAGENTO_EDITION}"-edition="${MAGENTO_VERSION}" \
        "/home/public_html/${VHOST_DOMAIN}/" || {
        _error "Failed to download Magento"
        exit 1
    }

    _success "Magento downloaded successfully"
}

installMagento() {
    _arrow "Installing Magento..."

    local install_cmd=(
        php -d memory_limit=-1 "/home/public_html/${VHOST_DOMAIN}/bin/magento" setup:install
        --db-host="$MYSQL_HOST"
        --db-name="${DATABASE_NAME}"
        --db-user="root"
        --db-password="$rootPass"
        --base-url=http://"$VHOST_DOMAIN"/
        --admin-firstname="admin"
        --admin-lastname="admin"
        --admin-email="admin@localhost.com"
        --admin-user="$ADMIN_USER"
        --admin-password="$ADMIN_PASSWORD"
        --backend-frontname="admin"
        --language="en_US"
        --currency="USD"
        --timezone="America/Chicago"
        --use-rewrites=1
    )

    if [[ $MAGENTO_VERSION == 2.4* ]]; then
        install_cmd+=(
            --search-engine=elasticsearch7
            --elasticsearch-host="elasticsearch"
            --elasticsearch-port="9200"
            --elasticsearch-index-prefix="${VHOST_DOMAIN}"
        )
    fi

    docker-compose exec --user nginx ${APP_PHP} "${install_cmd[@]}" || {
        _error "Failed to install Magento"
        exit 1
    }

    _success "Magento installed successfully"
}

printSuccessMessage() {
    echo ""
    echo "################################################################"
    echo ""
    echo " >> Domain               : ${VHOST_DOMAIN}"
    echo " >> PHP version          : ${APP_PHP}"
    echo " >> Document Root        : /home/public_html/${VHOST_DOMAIN}/"
    echo " >> Database name        : ${DATABASE_NAME}"
    echo " >> Database Password    : $rootPass"
    echo " >> Admin URL            : http://${VHOST_DOMAIN}/admin"
    echo " >> Admin User           : $ADMIN_USER"
    echo " >> Admin Password       : $ADMIN_PASSWORD"
    echo ""
    echo "################################################################"
}

################################################################################
# MAIN
################################################################################

main() {
    checkCmdDependencies

    [[ $# -lt 1 ]] && printUsage

    processArgs "$@"
    initDefaultArgs
    validateMagentoVersion
    validateBaseServices
    createSourceCodeFolder
    createMagentoDomain
    createDomainDatabase
    getMysqlInformation
    checkComposerAuth
    downloadMagento
    installMagento

    _success "Magento installation completed successfully"
    printSuccessMessage
    exit 0
}

main "$@"
