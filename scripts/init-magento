#!/usr/bin/env bash
#
# Download and install a fresh Magento instance
#

source "$(dirname "$0")/lib/services.sh"

VHOST_DOMAIN=""
MAGENTO_VERSION=""
MAGENTO_EDITION=""
APP_PHP=""

ADMIN_USER="admin"
ADMIN_PASSWORD="Admin123"
MYSQL_HOST="mysql"

# ── Usage ─────────────────────────────────────────────────────────────────────
_printUsage() {
    echo -n "Docker Init Fresh Magento
Version 2.0

./scripts/$(basename "$0") [ARG]...

    Options:
        --php-version             PHP version (e.g. php74, php81, php82, php83, php84).
                                  Run without args to see available versions.
        --domain                  Domain name (eg: test.com).
        --magento-version         Magento version (eg: 2.4.7).
        --magento-edition         Magento edition (community|enterprise).
        --debug                   Run command in debug mode.
        -h, --help                Display this help and exit.

    Examples:
      Install Magento community 2.4.7 with PHP 8.3:
        ./scripts/$(basename "$0") --domain=test.com --magento-version=2.4.7 --magento-edition=community --php-version=php83
"
    _print_banner
    exit 1
}

# ── Arg parsing ───────────────────────────────────────────────────────────────
processArgs() {
    for arg in "$@"; do
        case $arg in
            --domain=*)           VHOST_DOMAIN="${arg#*=}" ;;
            --magento-version=*)  MAGENTO_VERSION="${arg#*=}" ;;
            --magento-edition=*)  MAGENTO_EDITION="${arg#*=}" ;;
            --php-version=*)      APP_PHP="${arg#*=}" ;;
            --debug)              enable_debug ;;
            -h|--help)            _printUsage ;;
            *)                    _printUsage ;;
        esac
    done

    validateArgs
}

validateArgs() {
    local errors=0

    if [[ -z "$VHOST_DOMAIN" ]]; then
        _error "--domain=... parameter is missing."
        errors=$((errors + 1))
    fi
    if [[ -z "$MAGENTO_VERSION" ]]; then
        _error "--magento-version=... parameter is missing."
        errors=$((errors + 1))
    fi
    if [[ -z "$MAGENTO_EDITION" ]]; then
        _error "--magento-edition=... parameter is missing."
        errors=$((errors + 1))
    elif [[ "$MAGENTO_EDITION" != @(community|enterprise) ]]; then
        _error "Invalid --magento-edition. Must be: community|enterprise"
        errors=$((errors + 1))
    fi
    if [[ -z "$APP_PHP" ]]; then
        _error "--php-version=... parameter is missing."
        errors=$((errors + 1))
    fi

    if [[ $errors -gt 0 ]]; then
        exit 1
    fi

    # Sanitize domain
    if [[ "$VHOST_DOMAIN" == http* ]]; then
        VHOST_DOMAIN="$(sanitize_domain "$VHOST_DOMAIN")"
    fi
    validate_domain "$VHOST_DOMAIN"

    # Validate PHP version
    validate_php_version "$APP_PHP"
}

# ── Magento version validation ────────────────────────────────────────────────
validateMagentoVersion() {
    # Magento 2.4.x requires search engine
    if [[ "$MAGENTO_VERSION" == 2.4* ]]; then
        # Check if any search engine is running (elasticsearch or opensearch)
        local search_running=false
        if is_service_running elasticsearch 2>/dev/null; then
            search_running=true
        fi
        if is_service_running opensearch 2>/dev/null; then
            search_running=true
        fi
        if [[ "$search_running" == "false" ]]; then
            _die "Magento 2.4.x requires a search engine. Start elasticsearch or opensearch first."
        fi
    fi
}

# ── Detect search engine config for Magento install ───────────────────────────
getSearchEngineArgs() {
    # Magento < 2.4 doesn't use search engine
    if [[ "$MAGENTO_VERSION" != 2.4* ]]; then
        echo ""
        return
    fi

    # Prefer OpenSearch if running
    if is_service_running opensearch 2>/dev/null; then
        echo "--search-engine=opensearch --opensearch-host=opensearch --opensearch-port=9200 --opensearch-index-prefix=${VHOST_DOMAIN}"
        return
    fi

    # Fall back to Elasticsearch
    if is_service_running elasticsearch 2>/dev/null; then
        # Magento 2.4.6+ uses elasticsearch8, older uses elasticsearch7
        local es_engine="elasticsearch7"
        if [[ "$MAGENTO_VERSION" =~ ^2\.4\.([6-9]|[1-9][0-9]) ]]; then
            es_engine="elasticsearch8"
        fi
        echo "--search-engine=${es_engine} --elasticsearch-host=elasticsearch --elasticsearch-port=9200 --elasticsearch-index-prefix=${VHOST_DOMAIN}"
        return
    fi

    echo ""
}

# ── Steps ─────────────────────────────────────────────────────────────────────
createSourceCodeFolder() {
    if [[ -d "${SOURCE_DIR}/${VHOST_DOMAIN}" ]] && [[ "$(ls -A "${SOURCE_DIR}/${VHOST_DOMAIN}" 2>/dev/null)" ]]; then
        _die "${SOURCE_DIR}/${VHOST_DOMAIN} is not empty. Remove it first or choose another domain."
    fi

    _arrow "Creating source directory..."
    mkdir -p "${SOURCE_DIR}/${VHOST_DOMAIN}" || _die "Cannot create source directory"
    _success "Source directory created"
}

downloadMagento() {
    _arrow "Downloading Magento ${MAGENTO_EDITION} ${MAGENTO_VERSION}..."
    dc exec --user nginx "$APP_PHP" php -d memory_limit=-1 /usr/bin/composer create-project \
        --repository=https://repo.magento.com/ \
        "magento/project-${MAGENTO_EDITION}-edition=${MAGENTO_VERSION}" \
        "/home/public_html/${VHOST_DOMAIN}/" \
        || _die "Cannot download Magento source code"
    _success "Magento ${MAGENTO_EDITION} ${MAGENTO_VERSION} downloaded"
}

installMagento() {
    local root_pass
    root_pass="$(get_mysql_root_password)"

    local search_args
    search_args="$(getSearchEngineArgs)"

    _arrow "Installing Magento ${MAGENTO_EDITION} ${MAGENTO_VERSION}..."

    # Build install command
    local install_cmd="php -d memory_limit=-1 /home/public_html/${VHOST_DOMAIN}/bin/magento setup:install"
    install_cmd+=" --db-host=${MYSQL_HOST}"
    install_cmd+=" --db-name=${DATABASE_NAME}"
    install_cmd+=" --db-user=root"
    install_cmd+=" --db-password=${root_pass}"
    install_cmd+=" --base-url=http://${VHOST_DOMAIN}/"
    install_cmd+=" --admin-firstname=admin"
    install_cmd+=" --admin-lastname=admin"
    install_cmd+=" --admin-email=admin@localhost.com"
    install_cmd+=" --admin-user=${ADMIN_USER}"
    install_cmd+=" --admin-password=${ADMIN_PASSWORD}"
    install_cmd+=" --backend-frontname=admin"
    install_cmd+=" --language=en_US"
    install_cmd+=" --currency=USD"
    install_cmd+=" --timezone=America/Chicago"
    install_cmd+=" --use-rewrites=1"

    # Add search engine args if applicable
    if [[ -n "$search_args" ]]; then
        install_cmd+=" ${search_args}"
    fi

    dc exec --user nginx "$APP_PHP" $install_cmd \
        || _die "Cannot install Magento"

    _success "Magento installed successfully!"
}

printSuccessMessage() {
    local root_pass
    root_pass="$(get_mysql_root_password)"

    echo ""
    echo "################################################################"
    echo ""
    echo " >> Domain               : ${VHOST_DOMAIN}"
    echo " >> PHP version          : ${APP_PHP}"
    echo " >> Document Root        : /home/public_html/${VHOST_DOMAIN}/"
    echo " >> Nginx Config         : ${NGINX_CONF_DIR}/${VHOST_DOMAIN}.conf"
    echo " >> Database name        : ${DATABASE_NAME}"
    echo " >> Database User        : root"
    echo " >> Database Password    : ${root_pass}"
    echo " >> Admin URL            : http://${VHOST_DOMAIN}/admin"
    echo " >> Admin User           : ${ADMIN_USER}"
    echo " >> Admin Password       : ${ADMIN_PASSWORD}"
    echo ""
    echo "################################################################"
}

# ── Main ──────────────────────────────────────────────────────────────────────
main() {
    require_root_dir
    [[ $# -lt 1 ]] && _printUsage

    processArgs "$@"

    # Generate unique database name
    DATABASE_NAME="magento_$(date +%s)"

    # Validate
    validateMagentoVersion
    require_full_stack "$APP_PHP"

    # Create source folder
    createSourceCodeFolder

    # Create vhost via create-vhost script
    _arrow "Creating nginx virtual host..."
    "${SCRIPTS_DIR}/create-vhost" \
        --domain="${VHOST_DOMAIN}" \
        --app=magento2 \
        --root-dir="${VHOST_DOMAIN}" \
        --php-version="${APP_PHP}"

    # Create database
    _arrow "Creating database ${DATABASE_NAME}..."
    "${SCRIPTS_DIR}/database" create --database-name="${DATABASE_NAME}"

    # Setup composer auth
    check_composer_auth "$APP_PHP"

    # Download & install
    downloadMagento
    installMagento

    printSuccessMessage
}

main "$@"
