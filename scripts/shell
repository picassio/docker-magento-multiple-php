#!/usr/bin/env bash
source "$(dirname "$0")/lib/docker.sh"

if [[ -z "${1:-}" ]]; then
    _error "Usage: ./scripts/shell <php-version>"
    _arrow "Example: ./scripts/shell php83"
    _arrow "Available: $(get_available_php_versions | tr '\n' ', ' | sed 's/,$//')"
    exit 1
fi

validate_php_version "$1"
require_service "$1"
dc exec --user nginx "$@" bash
