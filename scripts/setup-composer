#!/usr/bin/env bash
#
# Setup Composer auth for repo.magento.com
#

source "$(dirname "$0")/lib/docker.sh"

# ── Usage ─────────────────────────────────────────────────────────────────────
_printUsage() {
    echo -n "Composer Auth Setup
Version 2.0

./scripts/$(basename "$0") [OPTION]...

    Options:
        --php-version               PHP version to configure (e.g. php81, php82, php83).
                                    Run without args to see available versions.
        --debug                     Run command in debug mode.
        -h, --help                  Display this help and exit.

    Examples:
        ./scripts/$(basename "$0") --php-version=php83

"
    _print_banner
    exit 1
}

# ── Arg parsing ───────────────────────────────────────────────────────────────
processArgs() {
    APP_PHP=""

    for arg in "$@"; do
        case $arg in
            --php-version=*) APP_PHP="${arg#*=}" ;;
            --debug)         enable_debug ;;
            -h|--help)       _printUsage ;;
            *)               _printUsage ;;
        esac
    done

    validate_php_version "$APP_PHP"
}

# ── Main ──────────────────────────────────────────────────────────────────────
main() {
    require_root_dir
    [[ $# -lt 1 ]] && _printUsage

    processArgs "$@"
    require_service "$APP_PHP"
    check_composer_auth "$APP_PHP"

    _success "Done!"
}

main "$@"
