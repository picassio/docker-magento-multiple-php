#!/usr/bin/env bash
#
# Composer Authentication Setup Script
# Configure Magento repository authentication
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

source "${SCRIPT_DIR}/lib/common.sh"

shopt -s extglob

################################################################################
# CONSTANTS
################################################################################

readonly VERSION="1.0.0"
readonly VALID_PHP_VERSIONS="php70 php71 php72 php73 php74 php74-c2 php81-c2 php82"
readonly MAGENTO_USERNAME_PROP="http-basic.repo.magento.com.username"
readonly MAGENTO_PASSWORD_PROP="http-basic.repo.magento.com.password"

################################################################################
# GLOBAL VARIABLES
################################################################################

APP_PHP=""
PUBLIC_KEY=""
PRIVATE_KEY=""

################################################################################
# FUNCTIONS
################################################################################

printUsage() {
    cat <<EOF
Composer Authentication Setup Tool
Version $VERSION

Configure Composer authentication for Magento repository access.

./scripts/$(basename "$0") [OPTIONS]...

Options:
    --php-version             PHP container version (${VALID_PHP_VERSIONS// /|})
    -h, --help                Display this help

Examples:
    ./scripts/$(basename "$0") --php-version=php74
EOF
    _printPoweredBy
    exit 1
}

processArgs() {
    [[ $# -lt 1 ]] && printUsage

    for arg in "$@"; do
        case "$arg" in
            --php-version=*)
                APP_PHP="${arg#*=}"
                ;;
            -h|--help)
                printUsage
                ;;
            *)
                _error "Unknown option: $arg"
                printUsage
                ;;
        esac
    done

    validateArgs
}

validateArgs() {
    if [[ -z "$APP_PHP" ]]; then
        _error "--php-version parameter is required"
        exit 1
    fi

    if [[ ! " $VALID_PHP_VERSIONS " =~ " $APP_PHP " ]]; then
        _error "Invalid PHP version: $APP_PHP"
        _error "Valid versions: ${VALID_PHP_VERSIONS}"
        exit 1
    fi
}

validateBaseServices() {
    _arrow "Checking if ${APP_PHP} container is running..."
    
    if isServiceRunning "${APP_PHP}"; then
        _success "${APP_PHP} container is running"
    else
        _error "${APP_PHP} container is not running"
        _error "Start it with: docker-compose up -d ${APP_PHP}"
        exit 1
    fi
}

checkComposerAuth() {
    _arrow "Checking existing Composer authentication..."
    
    PUBLIC_KEY="$(docker-compose exec -T --user nginx ${APP_PHP} composer config --global $MAGENTO_USERNAME_PROP 2>/dev/null || true)"
    PRIVATE_KEY="$(docker-compose exec -T --user nginx ${APP_PHP} composer config --global $MAGENTO_PASSWORD_PROP 2>/dev/null || true)"

    if [[ -n "$PUBLIC_KEY" ]] && [[ -n "$PRIVATE_KEY" ]]; then
        _success "Composer authentication already configured"
        _warning "Username: $PUBLIC_KEY"
        return 0
    else
        return 1
    fi
}

promptForCredentials() {
    echo ""
    echo "Composer authentication required for repo.magento.com"
    echo "Get your keys from: https://marketplace.magento.com/customer/accessKeys/"
    echo ""
    
    read -r -p "    Public Key (Username): " PUBLIC_KEY
    read -r -p "    Private Key (Password): " PRIVATE_KEY
    echo ""

    if [[ -z "$PUBLIC_KEY" ]] || [[ -z "$PRIVATE_KEY" ]]; then
        _error "Both public and private keys are required"
        exit 1
    fi
}

configureAuth() {
    _arrow "Configuring Composer authentication..."
    
    docker-compose exec -T --user nginx ${APP_PHP} composer config --global http-basic.repo.magento.com "${PUBLIC_KEY}" "${PRIVATE_KEY}" || {
        _error "Failed to configure Composer authentication"
        exit 1
    }
    
    _success "Composer authentication configured successfully"
}

################################################################################
# MAIN
################################################################################

main() {
    checkCmdDependencies
    processArgs "$@"
    validateBaseServices

    if checkComposerAuth; then
        _success "No configuration needed"
    else
        promptForCredentials
        configureAuth
    fi

    _success "Operation completed successfully"
    exit 0
}

main "$@"
