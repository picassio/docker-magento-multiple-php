#!/usr/bin/env bash
#
# MySQL Database Management Script
# Manage databases: list, create, export, import, drop
#

set -e

# Get the directory where the script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Source common library
# shellcheck source=lib/common.sh
source "${SCRIPT_DIR}/lib/common.sh"

# Enable extended pattern matching
shopt -s extglob

################################################################################
# CONSTANTS
################################################################################

readonly VERSION="1.0.0"
readonly DATABASE_PATTERN="^([[:alnum:]]([[:alnum:]_]{0,61}[[:alnum:]]))$"

################################################################################
# GLOBAL VARIABLES
################################################################################

COMMAND=""
DATABASE_NAME=""
DATABASE_IMPORT_SOURCE_NAME=""
DATABASE_IMPORT_TARGET_NAME=""
IMPORT_DIR=""
EXPORT_DIR=""
rootPass=""

################################################################################
# SCRIPT FUNCTIONS
################################################################################

# Print usage information
printUsage() {
    cat <<EOF
MySQL Database Management Tool
Version $VERSION

./scripts/$(basename "$0") [COMMAND] [OPTIONS]...

Commands:
    list                      List all databases
    create                    Create a new database
    export                    Export database to SQL file
    import                    Import SQL file into database
    drop                      Drop (delete) a database

Options:
    create:
        --database-name       Database name to create

    export:
        --database-name       Database name to export

    drop:
        --database-name       Database name to drop

    import:
        --source              SQL file name (must be in databases/import/)
        --target              Target database name

    -h, --help                Display this help and exit

Examples:
    List databases:
        ./scripts/$(basename "$0") list

    Create database:
        ./scripts/$(basename "$0") create --database-name=mydb

    Export database:
        ./scripts/$(basename "$0") export --database-name=mydb

    Import database:
        ./scripts/$(basename "$0") import --source=backup.sql --target=mydb

    Drop database:
        ./scripts/$(basename "$0") drop --database-name=mydb
EOF
    _printPoweredBy
    exit 1
}

# Initialize default arguments
initDefaultArgs() {
    IMPORT_DIR="${PROJECT_ROOT}/databases/import"
    EXPORT_DIR="${PROJECT_ROOT}/databases/export"

    # Create directories if they don't exist
    mkdir -p "$IMPORT_DIR" "$EXPORT_DIR"

    initYesNoPrompt
}

# Process command line arguments
processArgs() {
    [[ $# -lt 1 ]] && printUsage

    # First argument is the command
    case "$1" in
        create|export|drop|import|list)
            COMMAND="$1"
            shift
            ;;
        -h|--help)
            printUsage
            ;;
        *)
            _error "Unknown command: $1"
            printUsage
            ;;
    esac

    # Process remaining arguments
    for arg in "$@"; do
        case "$arg" in
            --database-name=*)
                DATABASE_NAME="${arg#*=}"
                ;;
            --source=*)
                DATABASE_IMPORT_SOURCE_NAME="${arg#*=}"
                ;;
            --target=*)
                DATABASE_IMPORT_TARGET_NAME="${arg#*=}"
                ;;
            -h|--help)
                printUsage
                ;;
            *)
                _error "Unknown option: $arg"
                printUsage
                ;;
        esac
    done

    validateArgs
}

# Validate arguments based on command
validateArgs() {
    local error_count=0

    case "$COMMAND" in
        create|export|drop)
            if [[ -z "$DATABASE_NAME" ]]; then
                _error "--database-name parameter is required for '$COMMAND' command"
                ((error_count++))
            fi
            ;;
        import)
            if [[ -z "$DATABASE_IMPORT_SOURCE_NAME" ]]; then
                _error "--source parameter is required for 'import' command"
                ((error_count++))
            fi
            if [[ -z "$DATABASE_IMPORT_TARGET_NAME" ]]; then
                _error "--target parameter is required for 'import' command"
                ((error_count++))
            fi
            ;;
    esac

    [[ "$error_count" -gt 0 ]] && exit 1
}

# Check if MySQL container is running
checkMysqlContainerRunning() {
    _arrow "Checking MySQL container status..."

    if isServiceRunning "mysql"; then
        _success "MySQL container is running"
    else
        _error "MySQL container is not running"
        _error "Start it with: docker-compose up -d mysql"
        exit 1
    fi
}

# Validate database name format
checkDatabaseName() {
    if [[ $DATABASE_NAME =~ $DATABASE_PATTERN ]]; then
        _success "Database name is valid"
    else
        _error "Invalid database name: $DATABASE_NAME"
        _error "Database name must be alphanumeric with underscores, 1-63 characters"
        exit 1
    fi
}

# Check if database file is valid
checkDatabaseFileName() {
    if [[ $(echo "${DATABASE_IMPORT_SOURCE_NAME}" | awk -F. '{print $NF}') != "sql" ]]; then
        _error "Database source file must have .sql extension"
        _error "Example: backup.sql"
        exit 1
    elif [[ -f "${IMPORT_DIR}/${DATABASE_IMPORT_SOURCE_NAME}" ]]; then
        _success "Database source file exists"
    else
        _error "Database source file not found: ${IMPORT_DIR}/${DATABASE_IMPORT_SOURCE_NAME}"
        exit 1
    fi
}

# Check if database exists
databaseExists() {
    local db_name="$1"
    local result

    result=$(docker-compose exec -T mysql mysql -u root -p"${rootPass}" --skip-column-names \
        -e "SHOW DATABASES LIKE '${db_name}'" 2>&1 | grep -v "Using a password")

    if [[ "$result" == "$db_name" ]]; then
        return 0
    else
        return 1
    fi
}

# List all databases
listDatabases() {
    _arrow "Listing all databases..."
    echo ""

    docker-compose exec mysql mysql -u root --password="${rootPass}" \
        -e "SHOW DATABASES" 2>&1 | grep -v "Using a password" || {
        _error "Failed to list databases"
        exit 1
    }
}

# Create a new database
createDatabase() {
    _arrow "Validating database name..."
    checkDatabaseName

    _arrow "Checking if database exists..."
    if databaseExists "$DATABASE_NAME"; then
        _error "Database '$DATABASE_NAME' already exists"
        _error "Please choose a different name"
        exit 1
    fi

    _arrow "Creating database '$DATABASE_NAME'..."
    docker-compose exec -T mysql mysql -u root -p"${rootPass}" --skip-column-names \
        -e "CREATE DATABASE ${DATABASE_NAME}" 2>&1 | grep -v "Using a password" || {
        _error "Failed to create database"
        exit 1
    }

    _success "Database '$DATABASE_NAME' created successfully"
    echo ""
    listDatabases
}

# Export database to SQL file
exportDatabase() {
    local backup_date
    backup_date=$(date +"%Y-%m-%d")

    _arrow "Checking if database exists..."
    if ! databaseExists "$DATABASE_NAME"; then
        _error "Database '$DATABASE_NAME' does not exist"
        exit 1
    fi

    _success "Database exists"

    local export_file="${EXPORT_DIR}/${DATABASE_NAME}-${backup_date}.sql"

    _arrow "Exporting database to: $export_file"
    docker-compose exec -T mysql /usr/bin/mysqldump -u root --password="${rootPass}" \
        "${DATABASE_NAME}" 2>&1 | grep -v "Using a password" > "$export_file" || {
        _error "Failed to export database"
        exit 1
    }

    _success "Database exported successfully"
    echo ""
    echo "  Export file: $export_file"
    echo "  File size: $(du -h "$export_file" | cut -f1)"
}

# Import SQL file into database
importDatabase() {
    _arrow "Validating source file..."
    checkDatabaseFileName

    _arrow "Checking if target database exists..."
    if ! databaseExists "$DATABASE_IMPORT_TARGET_NAME"; then
        _error "Target database '$DATABASE_IMPORT_TARGET_NAME' does not exist"
        _error "Create it first with: ./scripts/database create --database-name=$DATABASE_IMPORT_TARGET_NAME"
        exit 1
    fi

    _success "Target database exists"

    _arrow "Importing data into '$DATABASE_IMPORT_TARGET_NAME'..."
    docker-compose exec -T mysql mysql -u root -p"${rootPass}" \
        "${DATABASE_IMPORT_TARGET_NAME}" < "${IMPORT_DIR}/${DATABASE_IMPORT_SOURCE_NAME}" 2>&1 | grep -v "Using a password" || {
        _error "Failed to import database"
        exit 1
    }

    _success "Database imported successfully into '$DATABASE_IMPORT_TARGET_NAME'"
}

# Drop (delete) database
dropDatabase() {
    _arrow "Validating database name..."
    checkDatabaseName

    _arrow "Checking if database exists..."
    if ! databaseExists "$DATABASE_NAME"; then
        _error "Database '$DATABASE_NAME' does not exist"
        exit 1
    fi

    _success "Database exists"

    echo ""
    _warning "WARNING: This will permanently delete database '$DATABASE_NAME'"

    if askYesOrNo "Are you sure you want to continue?"; then
        _arrow "Dropping database '$DATABASE_NAME'..."
        docker-compose exec -T mysql mysql -u root -p"${rootPass}" --skip-column-names \
            -e "DROP DATABASE ${DATABASE_NAME}" 2>&1 | grep -v "Using a password" || {
            _error "Failed to drop database"
            exit 1
        }

        _success "Database '$DATABASE_NAME' dropped successfully"
        echo ""
        listDatabases
    else
        _warning "Operation cancelled"
        exit 0
    fi
}

# Execute the requested command
executeCommand() {
    case "$COMMAND" in
        list)
            listDatabases
            ;;
        create)
            createDatabase
            ;;
        export)
            exportDatabase
            ;;
        import)
            importDatabase
            ;;
        drop)
            dropDatabase
            ;;
    esac
}

################################################################################
# MAIN
################################################################################

main() {
    checkCmdDependencies

    processArgs "$@"
    initDefaultArgs

    checkMysqlContainerRunning
    getMysqlInformation

    executeCommand

    _success "Operation completed successfully"
    exit 0
}

main "$@"
