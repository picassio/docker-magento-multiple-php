#!/usr/bin/env bash
#
# Xdebug management — enable/disable/status per PHP version
#

source "$(dirname "$0")/lib/docker.sh"

# ── Usage ─────────────────────────────────────────────────────────────────────
_printUsage() {
    echo -n "Docker Xdebug tools
Version 2.0

./scripts/$(basename "$0") [OPT] [ARG]...

    Options:
        enable                    Enable Xdebug.
        disable                   Disable Xdebug.
        status                    Show Xdebug status.
    Args:
        --php-version             PHP version (e.g. php74, php81, php82, php83, php84).
                                  Run without args to see available versions.
        -h, --help                Display this help and exit.

    Examples:
      Disable Xdebug for PHP 8.2
        ./scripts/$(basename "$0") disable --php-version=php82
      Enable Xdebug for PHP 8.3
        ./scripts/$(basename "$0") enable --php-version=php83
      Check Xdebug status for PHP 8.1
        ./scripts/$(basename "$0") status --php-version=php81
"
    _print_banner
    exit 1
}

# ── Arg parsing ───────────────────────────────────────────────────────────────
processArgs() {
    COMMAND=""
    APP_PHP=""

    case "${1:-}" in
        enable|disable|status)
            COMMAND="$1"
            for arg in "${@:2}"; do
                case $arg in
                    --php-version=*) APP_PHP="${arg#*=}" ;;
                    --debug) enable_debug ;;
                    -h|--help) _printUsage ;;
                    *) _printUsage ;;
                esac
            done
            ;;
        -h|--help) _printUsage ;;
        *) _printUsage ;;
    esac

    validate_php_version "$APP_PHP"
}

# ── Xdebug operations ────────────────────────────────────────────────────────
statusXdebug() {
    _arrow "Checking Xdebug status for ${APP_PHP}..."
    if dc exec "$APP_PHP" php -m 2>/dev/null | grep -qi xdebug; then
        _success "${APP_PHP}: Xdebug enabled"
        return 0
    else
        _warning "${APP_PHP}: Xdebug disabled"
        return 1
    fi
}

enableXdebug() {
    if statusXdebug; then
        _warning "Xdebug already enabled, nothing to do."
        return
    fi

    local php_ini="${CONF_DIR}/php/${APP_PHP}/php.ini"
    if [[ ! -f "$php_ini" ]]; then
        _die "PHP ini not found: $php_ini"
    fi

    _arrow "Enabling Xdebug for ${APP_PHP}..."
    sed -i 's/;zend_extension=xdebug/zend_extension=xdebug/g' "$php_ini" \
        || _die "Cannot update Xdebug setting in $php_ini"
    _success "Xdebug enabled"

    _arrow "Restarting ${APP_PHP} container..."
    dc restart "$APP_PHP" || _die "${APP_PHP} restart failed"
    _success "${APP_PHP} restarted"
}

disableXdebug() {
    if ! statusXdebug; then
        _warning "Xdebug already disabled, nothing to do."
        return
    fi

    local php_ini="${CONF_DIR}/php/${APP_PHP}/php.ini"
    if [[ ! -f "$php_ini" ]]; then
        _die "PHP ini not found: $php_ini"
    fi

    _arrow "Disabling Xdebug for ${APP_PHP}..."
    sed -i 's/zend_extension=xdebug/;zend_extension=xdebug/g' "$php_ini" \
        || _die "Cannot update Xdebug setting in $php_ini"
    _success "Xdebug disabled"

    _arrow "Restarting ${APP_PHP} container..."
    dc restart "$APP_PHP" || _die "${APP_PHP} restart failed"
    _success "${APP_PHP} restarted"
}

# ── Main ──────────────────────────────────────────────────────────────────────
main() {
    require_root_dir
    [[ $# -lt 1 ]] && _printUsage

    processArgs "$@"
    require_service "$APP_PHP"

    case "$COMMAND" in
        enable)  enableXdebug  ;;
        disable) disableXdebug ;;
        status)  statusXdebug  ;;
    esac

    _success "Done!"
}

main "$@"
