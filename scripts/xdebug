#!/usr/bin/env bash
#
# Xdebug Management Script
# Enable, disable, and check Xdebug status for PHP containers
#

set -e

# Get script directory and project root
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Source common library
source "${SCRIPT_DIR}/lib/common.sh"

shopt -s extglob

################################################################################
# CONSTANTS
################################################################################

readonly VERSION="1.0.0"
readonly VALID_PHP_VERSIONS="php70 php71 php72 php73 php74 php74-c2 php81-c2"

################################################################################
# GLOBAL VARIABLES
################################################################################

COMMAND=""
APP_PHP=""
PHP_INI_LOCATION=""
XDEBUG_STATUS=0

################################################################################
# FUNCTIONS
################################################################################

printUsage() {
    cat <<EOF
Xdebug Management Tool
Version $VERSION

./scripts/$(basename "$0") [COMMAND] [OPTIONS]...

Commands:
    enable                    Enable Xdebug
    disable                   Disable Xdebug
    status                    Check Xdebug status

Options:
    --php-version             PHP container version (${VALID_PHP_VERSIONS// /|})
    -h, --help                Display this help

Examples:
    ./scripts/$(basename "$0") enable --php-version=php74
    ./scripts/$(basename "$0") disable --php-version=php72
    ./scripts/$(basename "$0") status --php-version=php74
EOF
    _printPoweredBy
    exit 1
}

processArgs() {
    [[ $# -lt 1 ]] && printUsage

    case "$1" in
        enable|disable|status)
            COMMAND="$1"
            shift
            ;;
        -h|--help)
            printUsage
            ;;
        *)
            _error "Unknown command: $1"
            printUsage
            ;;
    esac

    for arg in "$@"; do
        case "$arg" in
            --php-version=*)
                APP_PHP="${arg#*=}"
                ;;
            -h|--help)
                printUsage
                ;;
            *)
                _error "Unknown option: $arg"
                printUsage
                ;;
        esac
    done

    validateArgs
}

validateArgs() {
    if [[ -z "$APP_PHP" ]]; then
        _error "--php-version parameter is required"
        exit 1
    fi

    if [[ ! " $VALID_PHP_VERSIONS " =~ " $APP_PHP " ]]; then
        _error "Invalid PHP version: $APP_PHP"
        _error "Valid versions: ${VALID_PHP_VERSIONS}"
        exit 1
    fi
}

initDefaultArgs() {
    PHP_INI_LOCATION="${PROJECT_ROOT}/conf/php/${APP_PHP}/php.ini"
    initYesNoPrompt
}

checkPhpContainerRunning() {
    _arrow "Checking ${APP_PHP} container status..."

    if isServiceRunning "${APP_PHP}"; then
        _success "${APP_PHP} container is running"
    else
        _error "${APP_PHP} container is not running"
        _error "Start it with: docker-compose up -d ${APP_PHP}"
        exit 1
    fi
}

statusXdebug() {
    _arrow "Checking Xdebug status for ${APP_PHP}..."

    if docker-compose exec "${APP_PHP}" php -i 2>/dev/null | grep -q xdebug; then
        _success "${APP_PHP}: Xdebug is enabled"
        XDEBUG_STATUS=1
    else
        _warning "${APP_PHP}: Xdebug is disabled"
        XDEBUG_STATUS=0
    fi
}

enableXdebug() {
    statusXdebug

    if [[ $XDEBUG_STATUS == 1 ]]; then
        _warning "Xdebug is already enabled"
        exit 0
    fi

    _arrow "Enabling Xdebug for ${APP_PHP}..."

    sed -i 's/;zend_extension=xdebug/zend_extension=xdebug/g' "$PHP_INI_LOCATION" || {
        _error "Failed to modify PHP configuration"
        exit 1
    }

    _success "Xdebug enabled"
    restartPhpContainer
}

disableXdebug() {
    statusXdebug

    if [[ $XDEBUG_STATUS == 0 ]]; then
        _warning "Xdebug is already disabled"
        exit 0
    fi

    _arrow "Disabling Xdebug for ${APP_PHP}..."

    sed -i 's/zend_extension=xdebug/;zend_extension=xdebug/g' "$PHP_INI_LOCATION" || {
        _error "Failed to modify PHP configuration"
        exit 1
    }

    _success "Xdebug disabled"
    restartPhpContainer
}

restartPhpContainer() {
    _arrow "Restarting ${APP_PHP} container..."

    docker-compose restart "${APP_PHP}" || {
        _error "Failed to restart ${APP_PHP}"
        exit 1
    }

    _success "${APP_PHP} container restarted"
}

executeCommand() {
    case "$COMMAND" in
        enable)
            enableXdebug
            ;;
        disable)
            disableXdebug
            ;;
        status)
            statusXdebug
            ;;
    esac
}

################################################################################
# MAIN
################################################################################

main() {
    checkCmdDependencies
    processArgs "$@"
    initDefaultArgs
    checkPhpContainerRunning
    executeCommand
    _success "Operation completed successfully"
    exit 0
}

main "$@"
