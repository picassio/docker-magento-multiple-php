#!/usr/bin/env bash
#
# SSL Certificate Management Script
# Create and configure SSL certificates using mkcert
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

source "${SCRIPT_DIR}/lib/common.sh"

shopt -s extglob

################################################################################
# CONSTANTS
################################################################################

readonly VERSION="1.0.0"

################################################################################
# GLOBAL VARIABLES
################################################################################

VHOST_DOMAIN=""
SSL_DIR=""
NGINX_SITES_CONF_D=""
NGINX_SITES_CONF_D_SSL_FILE=""

################################################################################
# FUNCTIONS
################################################################################

printUsage() {
    cat <<EOF
SSL Certificate Management Tool
Version $VERSION

./scripts/$(basename "$0") [OPTIONS]...

Options:
    --domain                  Domain name (e.g., example.com)
    -h, --help                Display this help

Examples:
    ./scripts/$(basename "$0") --domain=test.local
EOF
    _printPoweredBy
    exit 1
}

processArgs() {
    [[ $# -lt 1 ]] && printUsage

    for arg in "$@"; do
        case "$arg" in
            --domain=*)
                VHOST_DOMAIN="${arg#*=}"
                ;;
            -h|--help)
                printUsage
                ;;
            *)
                _error "Unknown option: $arg"
                printUsage
                ;;
        esac
    done

    validateArgs
}

validateArgs() {
    if [[ -z "$VHOST_DOMAIN" ]]; then
        _error "--domain parameter is required"
        exit 1
    fi
}

initDefaultArgs() {
    SSL_DIR="${PROJECT_ROOT}/conf/nginx/ssl"
    NGINX_SITES_CONF_D="${PROJECT_ROOT}/conf/nginx/conf.d"
    NGINX_SITES_CONF_D_SSL_FILE="${NGINX_SITES_CONF_D}/${VHOST_DOMAIN}-ssl.conf"
    
    initYesNoPrompt
    
    # Create SSL directory if it doesn't exist
    mkdir -p "$SSL_DIR"
}

checkSslCommand() {
    if ! command_exists mkcert; then
        _error "mkcert command not found"
        _warning "Install mkcert on Ubuntu with:"
        cat <<EOF
    sudo apt-get install libnss3-tools -y
    sudo wget https://github.com/FiloSottile/mkcert/releases/download/v1.4.3/mkcert-v1.4.3-linux-amd64 -O /usr/local/bin/mkcert
    sudo chmod +x /usr/local/bin/mkcert
    mkcert -install
EOF
        exit 1
    fi
}

checkDomainExists() {
    _arrow "Checking if domain configuration exists..."
    
    if [[ -f "${NGINX_SITES_CONF_D}/${VHOST_DOMAIN}.conf" ]]; then
        _success "Domain configuration exists"
    else
        _error "Domain configuration not found: ${NGINX_SITES_CONF_D}/${VHOST_DOMAIN}.conf"
        _error "Create the domain first with the create-vhost script"
        exit 1
    fi
}

createCertificate() {
    _arrow "Creating SSL certificate for ${VHOST_DOMAIN}..."
    
    local key_file="${VHOST_DOMAIN}.key"
    local cert_file="${VHOST_DOMAIN}.crt"
    
    mkcert -key-file "$key_file" -cert-file "$cert_file" "$VHOST_DOMAIN" || {
        _error "Failed to create certificate"
        exit 1
    }
    
    _arrow "Moving certificates to SSL directory..."
    mv "$key_file" "$cert_file" "${SSL_DIR}/" || {
        _error "Failed to move certificates"
        exit 1
    }
    
    _success "SSL certificate created successfully"
}

prepareSslVhostContent() {
    _arrow "Creating Nginx SSL configuration..."
    
    cat > "$NGINX_SITES_CONF_D_SSL_FILE" <<EOF
server {
    server_name ${VHOST_DOMAIN};

    listen 443 ssl;

    ssl_certificate /etc/nginx/ssl/${VHOST_DOMAIN}.crt;
    ssl_certificate_key /etc/nginx/ssl/${VHOST_DOMAIN}.key;

    client_max_body_size 100M;
    
    location / {
        proxy_pass http://127.0.0.1:80;
        proxy_set_header Host \$http_host;
        proxy_set_header X-Forwarded-Host \$http_host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header Ssl-Offloaded "1";
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Port 443;

        proxy_buffer_size          128k;
        proxy_buffers              4 256k;
        proxy_busy_buffers_size    256k;

        proxy_read_timeout 600;
        proxy_connect_timeout 600;
        proxy_send_timeout  600;
    }

    error_page 404 /404.html;
    location = /40x.html {
    }

    error_page 500 502 503 504 /50x.html;
    location = /50x.html {
    }
}
EOF
    
    _success "Nginx SSL configuration created"
}

printSuccessMessage() {
    echo ""
    echo "################################################################"
    echo ""
    echo " >> Domain               : ${VHOST_DOMAIN}"
    echo " >> SSL Certificate      : ${SSL_DIR}/${VHOST_DOMAIN}.crt"
    echo " >> SSL Key              : ${SSL_DIR}/${VHOST_DOMAIN}.key"
    echo " >> Nginx SSL Config     : ${NGINX_SITES_CONF_D_SSL_FILE}"
    echo " >> HTTPS URL            : https://${VHOST_DOMAIN}"
    echo ""
    echo "################################################################"
}

################################################################################
# MAIN
################################################################################

main() {
    checkCmdDependencies
    checkSslCommand
    processArgs "$@"
    initDefaultArgs
    checkDomainExists
    createCertificate
    prepareSslVhostContent
    reloadNginx
    _success "SSL certificate setup completed successfully"
    printSuccessMessage
    exit 0
}

main "$@"
