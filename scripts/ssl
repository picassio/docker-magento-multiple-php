#!/usr/bin/env bash
#
# SSL certificate setup — generate cert with mkcert and create nginx SSL vhost
#

source "$(dirname "$0")/lib/services.sh"

VHOST_DOMAIN=""

# ── Usage ─────────────────────────────────────────────────────────────────────
_printUsage() {
    echo -n "Docker SSL Setup
Version 2.0

./scripts/$(basename "$0") [ARG]...

    Options:
        --domain                  Domain name (eg: test.com).
        --debug                   Run command in debug mode.
        -h, --help                Display this help and exit.

    Examples:
      Enable SSL for domain test-magento.com:
        ./scripts/$(basename "$0") --domain=test-magento.com
"
    _print_banner
    exit 1
}

# ── Arg parsing ───────────────────────────────────────────────────────────────
processArgs() {
    for arg in "$@"; do
        case $arg in
            --domain=*) VHOST_DOMAIN="${arg#*=}" ;;
            --debug)    enable_debug ;;
            -h|--help)  _printUsage ;;
            *)          _printUsage ;;
        esac
    done

    if [[ -z "$VHOST_DOMAIN" ]]; then
        _error "--domain=... parameter is missing."
        exit 1
    fi

    VHOST_DOMAIN="$(sanitize_domain "$VHOST_DOMAIN")"
    validate_domain "$VHOST_DOMAIN"
}

# ── mkcert check ──────────────────────────────────────────────────────────────
checkSslCommand() {
    if ! command -v mkcert &>/dev/null; then
        _arrow "mkcert not found, installing..."
        local arch=$(dpkg --print-architecture 2>/dev/null || uname -m)
        local mkcert_arch="amd64"
        case "$arch" in
            arm64|aarch64) mkcert_arch="arm64" ;;
        esac
        local mkcert_url="https://github.com/FiloSottile/mkcert/releases/download/v1.4.3/mkcert-v1.4.3-linux-${mkcert_arch}"
        if curl -fsSL "$mkcert_url" -o /usr/local/bin/mkcert 2>/dev/null || \
           sudo curl -fsSL "$mkcert_url" -o /usr/local/bin/mkcert 2>/dev/null; then
            chmod +x /usr/local/bin/mkcert 2>/dev/null || sudo chmod +x /usr/local/bin/mkcert
            mkcert -install 2>/dev/null || true
            _success "mkcert installed"
        else
            _error "Failed to install mkcert. Install manually:"
            echo "    sudo wget $mkcert_url -O /usr/local/bin/mkcert"
            echo "    sudo chmod +x /usr/local/bin/mkcert"
            echo "    mkcert -install"
            exit 1
        fi
    fi
}

# ── Certificate creation ─────────────────────────────────────────────────────
createCertificate() {
    _arrow "Creating certificate for ${VHOST_DOMAIN}..."
    mkcert -key-file "${VHOST_DOMAIN}.key" -cert-file "${VHOST_DOMAIN}.crt" "${VHOST_DOMAIN}" \
        || _die "Cannot create certificate"

    _arrow "Moving certificate to ${NGINX_SSL_DIR}/"
    mv "${VHOST_DOMAIN}.key" "${VHOST_DOMAIN}.crt" "${NGINX_SSL_DIR}/"
    _success "Certificate created for ${VHOST_DOMAIN}"
}

# ── SSL vhost content ─────────────────────────────────────────────────────────
prepareSslVhostContent() {
    local ssl_conf="${NGINX_CONF_DIR}/${VHOST_DOMAIN}-ssl.conf"

    cat > "$ssl_conf" <<SSLEOF || _die "Cannot write to: ${ssl_conf}"
server {
    server_name ${VHOST_DOMAIN};

    listen 443 ssl;

    ssl_certificate /etc/nginx/ssl/${VHOST_DOMAIN}.crt;
    ssl_certificate_key /etc/nginx/ssl/${VHOST_DOMAIN}.key;

    client_max_body_size 100M;
    location / {
        proxy_pass http://127.0.0.1:80;
        proxy_set_header Host \$http_host;
        proxy_set_header X-Forwarded-Host \$http_host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header Ssl-Offloaded "1";
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Port 443;

        proxy_buffer_size          128k;
        proxy_buffers              4 256k;
        proxy_busy_buffers_size    256k;

        proxy_read_timeout 600;
        proxy_connect_timeout 600;
        proxy_send_timeout  600;
    }

    error_page 404 /404.html;
    location = /40x.html {
    }

    error_page 500 502 503 504 /50x.html;
    location = /50x.html {
    }
}
SSLEOF

    _success "SSL vhost config created: ${ssl_conf}"
}

# ── Main ──────────────────────────────────────────────────────────────────────
main() {
    require_root_dir
    checkSslCommand
    [[ $# -lt 1 ]] && _printUsage

    processArgs "$@"

    require_domain_config "$VHOST_DOMAIN"
    createCertificate
    prepareSslVhostContent
    reload_nginx

    _success "SSL enabled for ${VHOST_DOMAIN}!"
    echo "################################################################"
    echo ""
    echo " >> Domain               : ${VHOST_DOMAIN}"
    echo " >> SSL Config           : ${NGINX_CONF_DIR}/${VHOST_DOMAIN}-ssl.conf"
    echo ""
    echo "################################################################"
}

main "$@"
